---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowLeft, Shield, Clock, AlertTriangle, Mail } from '@lucide/astro';
---

<BaseLayout
  title="Warranty — TIP TIG Product Coverage"
  description="TIP TIG warranty coverage: 24 months for hot-wire modules, 12 months for wire feeders, 6 months for torches. Learn how to submit a claim."
>
  <section class="wr-hero">
    <div class="wr-hero-bg"></div>
    <div class="inner">
      <a href="/support" class="wr-back"><ArrowLeft size={16} /> All Support</a>
      <div class="wr-eyebrow">Product Coverage</div>
      <h1>Warranty<br><span class="blue">Information</span></h1>
      <p class="wr-desc">
        Every TIP TIG system is built for industrial reliability. Our warranty
        reflects our confidence in the quality of Austrian engineering.
      </p>
    </div>
  </section>

  <section class="wr-content">
    <div class="inner">
      <!-- Coverage Cards -->
      <div class="wr-coverage-grid">
        <div class="wr-cover-card reveal">
          <div class="wr-cover-months">24</div>
          <div class="wr-cover-label">Months</div>
          <h3>Hot-Wire Modules</h3>
          <p>Full coverage for the TIP TIG hot-wire unit including oscillation motor and control electronics.</p>
        </div>

        <div class="wr-cover-card reveal reveal-delay-1">
          <div class="wr-cover-months">12</div>
          <div class="wr-cover-label">Months</div>
          <h3>Wire Feeders</h3>
          <p>Coverage for wire feed mechanisms, drive rollers, and associated motor components.</p>
        </div>

        <div class="wr-cover-card reveal reveal-delay-2">
          <div class="wr-cover-months">6</div>
          <div class="wr-cover-label">Months</div>
          <h3>Torches & Accessories</h3>
          <p>Coverage for TIG torches and connecting cables under normal operating conditions.</p>
        </div>
      </div>

      <!-- What's Covered / Not Covered -->
      <div class="wr-details-grid">
        <div class="wr-detail-card reveal">
          <div class="wr-detail-icon covered"><Shield size={20} /></div>
          <h3>What's Covered</h3>
          <ul>
            <li>Manufacturing defects in materials and workmanship</li>
            <li>Electronic component failure under normal use</li>
            <li>Mechanical defects in motors and drive systems</li>
            <li>Control panel hardware and firmware issues</li>
            <li>Free replacement or repair at our discretion</li>
          </ul>
        </div>

        <div class="wr-detail-card reveal reveal-delay-1">
          <div class="wr-detail-icon excluded"><AlertTriangle size={20} /></div>
          <h3>Exclusions</h3>
          <ul>
            <li>Consumable parts (contact tips, gas nozzles, collets)</li>
            <li>Normal wear and tear components</li>
            <li>Damage from improper use, modification, or neglect</li>
            <li>Damage from incorrect voltage or power supply</li>
            <li>Unauthorized repairs or third-party modifications</li>
          </ul>
        </div>
      </div>

      <!-- Claims Process -->
      <div class="wr-claims reveal">
        <h3>How to Submit a Claim</h3>
        <div class="wr-claims-steps">
          <div class="wr-claim-step">
            <div class="wr-claim-num">1</div>
            <div>
              <strong>Gather Information</strong>
              <p>Prepare your serial number, proof of purchase, and a description of the issue.</p>
            </div>
          </div>
          <div class="wr-claim-step">
            <div class="wr-claim-num">2</div>
            <div>
              <strong>Contact Us</strong>
              <p>Email <a href="mailto:office@tiptig.com">office@tiptig.com</a> or reach out to your local Certified Partner.</p>
            </div>
          </div>
          <div class="wr-claim-step">
            <div class="wr-claim-num">3</div>
            <div>
              <strong>Assessment</strong>
              <p>Our technical team will review your claim and respond within 3 business days.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Full Legal Warranty Terms -->
  <section class="wr-legal">
    <div class="inner-legal">
      <h2 class="wr-legal-title reveal">Complete Warranty Terms</h2>
      <p class="wr-legal-intro reveal">
        Manufacturer: Ing. Siegfried Plasch, Baumayrweg 4, 4631 Krenglbach, Austria<br>
        Contact / RMA: <a href="mailto:office@tiptig.com">office@tiptig.com</a><br>
        Territorial scope: EU / EEA / CH / UK (procedures outside the EU may differ)
      </p>

      <div class="wr-legal-sections reveal">
        <div class="wr-legal-section">
          <h3>1. Coverage of this Warranty</h3>
          <p>
            This voluntary manufacturer's warranty covers defects in materials and workmanship
            arising during normal use within the warranty period. The provider will repair or replace
            affected components at their discretion to restore contractual functionality. Replaced
            parts become the provider's property. Repair or replacement does not extend or restart
            the warranty period.
          </p>
        </div>

        <div class="wr-legal-section">
          <h3>2. Commencement, Proof & Transferability</h3>
          <p>
            The warranty period begins on the purchase date shown on the original invoice/receipt
            of the first purchaser. Invoice and serial number are sufficient proof — no separate
            warranty certificate is required. The warranty is tied to the product by serial number
            and is transferable to subsequent owners.
          </p>
        </div>

        <div class="wr-legal-section">
          <h3>3. Warranty Periods per Product Family</h3>
          <ul>
            <li>Hot-wire module / power electronics / control units: <strong>24 months</strong></li>
            <li>Wire feeders / drives / controllers: <strong>12 months</strong></li>
            <li>TIG/automation torches, hose assemblies, cable harnesses: <strong>6 months</strong></li>
            <li>Software/firmware: no performance warranty; bug fixes via updates where available</li>
            <li>Wear & consumable parts: excluded</li>
          </ul>
        </div>

        <div class="wr-legal-section">
          <h3>4. What is Not Covered</h3>
          <ul>
            <li>Wear/consumable parts (e.g. contact tips, gas nozzles, ceramics, current tips, diffusers, seals/O-rings, hose-pack internals, liners, rollers, fuses, filters, lubricants)</li>
            <li>Improper use or failure to follow the manual (wrong parameters, insufficient cooling, incorrect shielding gas supply)</li>
            <li>Mechanical/chemical influences: drop, bending, corrosion, liquid ingress, contamination</li>
            <li>Electrical influences: over/undervoltage, lightning, EMC disturbances outside specification, wrong mains frequency, missing/faulty protective earth</li>
            <li>Interventions/modifications by unauthorized persons, non-approved accessories/third-party parts, tampered serial numbers</li>
            <li>Transport/storage damage after risk has passed; software conflicts caused by third-party systems</li>
          </ul>
        </div>

        <div class="wr-legal-section">
          <h3>5. Making a Claim (RMA Procedure)</h3>
          <ol>
            <li>Report the issue to <a href="mailto:office@tiptig.com">office@tiptig.com</a>, including: serial number, proof of purchase (copy), short fault description, meaningful photos/videos.</li>
            <li>Receive RMA number & return address (no acceptance without RMA).</li>
            <li>Packaging must be transport-safe, clean, free from operating media (e.g. coolants).</li>
            <li>The provider will assess the defect and repair or replace if covered; otherwise, you will receive a cost estimate.</li>
          </ol>
          <p>
            Unless expressly agreed otherwise, we do not cover costs for transport, travel,
            disassembly/re-installation or diagnostics. Mandatory costs under statutory warranty
            remain unaffected.
          </p>
        </div>

        <div class="wr-legal-section">
          <h3>6. Relation to Statutory Rights</h3>
          <p>
            This manufacturer's warranty applies in addition to your statutory warranty rights
            under Austrian/EU law (VGG/ABGB) and does not affect them. For consumers, repair
            or replacement is free of charge, including necessary ancillary and shipping costs.
            Contractual or statutory remedies (price reduction, rescission, damages) exist
            independently where legal requirements are met.
          </p>
        </div>

        <div class="wr-legal-section">
          <h3>7. Liability</h3>
          <p>
            Our liability under this warranty is limited to restoring functionality
            (repair/replacement). Further claims (e.g. production downtime, loss of profit,
            data loss) are excluded — except in cases of intent, gross negligence or personal
            injury. Mandatory statutory rights remain unaffected.
          </p>
        </div>

        <div class="wr-legal-section">
          <h3>8. Software / Firmware</h3>
          <p>
            Firmware updates may change certain functions; illustrations/manuals may slightly
            differ from the current state. Users should observe the operating manual and release notes.
          </p>
        </div>

        <div class="wr-legal-section">
          <h3>9. Governing Law, Language, Durable Medium</h3>
          <p>
            This warranty is governed by Austrian law, excluding its conflict-of-laws rules
            and the CISG; mandatory consumer protection at the consumer's place of residence
            remains unaffected. These terms are provided on a durable medium (PDF) and may
            be enclosed with the product. In case of discrepancies, the German version prevails.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wr-hero {
    padding: 140px 60px 60px;
    background: var(--white);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .wr-hero-bg {
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 900px; height: 900px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--sapphire-light) 0%, transparent 70%);
    pointer-events: none;
  }
  .inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .wr-hero .inner {
    animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .wr-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--sapphire);
    text-decoration: none;
    margin-bottom: 28px;
    transition: gap 0.2s;
  }
  .wr-back:hover { gap: 10px; }

  .wr-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 16px;
  }
  h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
  }
  .blue { color: var(--sapphire); }
  .wr-desc {
    font-size: 1rem;
    font-weight: 300;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Content */
  .wr-content {
    padding: 60px 60px 110px;
    background: var(--bg);
  }

  /* Coverage Cards */
  .wr-coverage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 48px;
  }
  .wr-cover-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 20px;
    padding: 36px 32px;
    text-align: center;
    transition: all 0.3s;
  }
  .wr-cover-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 32px rgba(27, 58, 140, 0.08);
    transform: translateY(-3px);
  }
  .wr-cover-months {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 3.5rem;
    color: var(--sapphire);
    line-height: 1;
  }
  .wr-cover-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sapphire);
    margin-bottom: 20px;
  }
  .wr-cover-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--black);
    margin-bottom: 10px;
  }
  .wr-cover-card p {
    font-size: 0.85rem;
    color: var(--gray-mid);
    line-height: 1.6;
    font-weight: 300;
  }

  /* Detail Cards */
  .wr-details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 48px;
  }
  .wr-detail-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 20px;
    padding: 36px 32px;
  }
  .wr-detail-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .wr-detail-icon.covered {
    background: #E8F5E9;
    color: #2E7D32;
  }
  .wr-detail-icon.excluded {
    background: #FFF3E0;
    color: #E65100;
  }
  .wr-detail-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--black);
    margin-bottom: 16px;
  }
  .wr-detail-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .wr-detail-card li {
    font-size: 0.88rem;
    color: var(--gray-mid);
    line-height: 1.5;
    font-weight: 300;
    padding-left: 20px;
    position: relative;
  }
  .wr-detail-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--sapphire-mid);
  }

  /* Claims */
  .wr-claims {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 20px;
    padding: 40px;
  }
  .wr-claims h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--black);
    margin-bottom: 28px;
  }
  .wr-claims-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .wr-claim-step {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .wr-claim-num {
    width: 32px; height: 32px;
    background: var(--sapphire);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 0.85rem;
  }
  .wr-claim-step strong {
    display: block;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--black);
    margin-bottom: 4px;
  }
  .wr-claim-step p {
    font-size: 0.85rem;
    color: var(--gray-mid);
    line-height: 1.6;
    font-weight: 300;
  }
  .wr-claim-step a {
    color: var(--sapphire);
    font-weight: 500;
  }

  /* Legal Terms */
  .wr-legal {
    padding: 80px 60px 110px;
    background: var(--white);
  }
  .inner-legal {
    max-width: 800px;
    margin: 0 auto;
  }
  .wr-legal-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--black);
    margin-bottom: 20px;
    text-align: center;
  }
  .wr-legal-intro {
    font-size: 0.88rem;
    color: var(--gray-mid);
    line-height: 1.7;
    font-weight: 400;
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--gray-light);
  }
  .wr-legal-intro a {
    color: var(--sapphire);
    font-weight: 500;
  }
  .wr-legal-section {
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--gray-light);
  }
  .wr-legal-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .wr-legal-section h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--black);
    margin-bottom: 12px;
  }
  .wr-legal-section p {
    font-size: 0.88rem;
    color: var(--gray-dark);
    line-height: 1.75;
    font-weight: 300;
  }
  .wr-legal-section ul,
  .wr-legal-section ol {
    padding-left: 20px;
    margin: 0 0 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .wr-legal-section li {
    font-size: 0.88rem;
    color: var(--gray-dark);
    line-height: 1.65;
    font-weight: 300;
  }
  .wr-legal-section li strong {
    font-weight: 600;
    color: var(--black);
  }
  .wr-legal-section a {
    color: var(--sapphire);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .wr-hero { padding: 120px 24px 48px; }
    .wr-content { padding: 36px 24px 72px; }
    .wr-coverage-grid { grid-template-columns: 1fr; }
    .wr-details-grid { grid-template-columns: 1fr; }
    .wr-claims-steps { grid-template-columns: 1fr; }
    .wr-claims { padding: 28px 24px; }
    .wr-legal { padding: 48px 24px 72px; }
  }
</style>
