---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactHero from '../../components/contact/ContactHero.astro';
import ContactForm from '../../components/contact/ContactForm.astro';
import ContactMap from '../../components/contact/ContactMap.astro';
import ContactLocations from '../../components/contact/ContactLocations.astro';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'TIP TIG',
  legalName: 'Ing. Siegfried Plasch e.U.',
  image: 'https://tiptig.com/images/logo-red-blue_new.webp',
  url: 'https://tiptig.com',
  telephone: '+43-7249-46795',
  email: 'office@tiptig.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gewerbepark 16',
    addressLocality: 'Krenglbach',
    postalCode: '4631',
    addressRegion: 'Oberösterreich',
    addressCountry: 'AT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 48.1356,
    longitude: 13.9272,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '17:00',
  },
  priceRange: '$$$$',
};
---

<BaseLayout
  lang="de"
  title="Kontakt — Nehmen Sie Kontakt auf"
  description="Kontaktieren Sie TIP TIG für Verkaufsanfragen, technischen Support oder um Ihren nächsten Händler zu finden. Hauptsitz in Krenglbach, Österreich."
  jsonLd={localBusinessSchema}
>
  <ContactHero lang="de" />
  <ContactForm lang="de" />
  <ContactMap lang="de" />
  <ContactLocations lang="de" />
</BaseLayout>
