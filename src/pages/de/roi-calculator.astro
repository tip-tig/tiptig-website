---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Calculator, TrendingUp, Clock, DollarSign } from '@lucide/astro';
---

<BaseLayout
  lang="de"
  title="ROI-Rechner — TIP TIG"
  description="Berechnen Sie Ihren Return on Investment mit TIP TIG. Sehen Sie, wie schnell sich das System in Ihrem Schweißbetrieb amortisiert."
>
  <section class="rc-hero">
    <div class="rc-hero-bg"></div>
    <div class="inner">
      <div class="rc-eyebrow">Business Case</div>
      <h1>ROI-<br><span class="blue">Rechner</span></h1>
      <p class="rc-desc">
        Geben Sie Ihre aktuellen Schweißparameter ein und sehen Sie,
        wie schnell sich TIP TIG in Ihrem Betrieb amortisiert.
      </p>
    </div>
  </section>

  <section class="rc-calc">
    <div class="inner">
      <div class="rc-layout">

        <!-- Eingabekarte -->
        <div class="rc-input-card reveal">
          <div class="rc-card-header">
            <Calculator size={20} />
            <h2>Ihr aktueller Betrieb</h2>
          </div>

          <div class="rc-field">
            <label for="rc-process">Aktuelles Schweißverfahren</label>
            <select id="rc-process">
              <option value="tig" selected>Konventionelles WIG (GTAW)</option>
              <option value="mig">MIG/MAG (GMAW)</option>
              <option value="stick">Stabelektrode (SMAW)</option>
              <option value="fcaw">Fülldraht (FCAW)</option>
            </select>
          </div>

          <div class="rc-field-row">
            <div class="rc-field">
              <label for="rc-welders">Anzahl Schweißer</label>
              <input type="number" id="rc-welders" value="1" min="1" max="100" step="1" />
            </div>
            <div class="rc-field">
              <label for="rc-hours">Schweißstunden / Woche</label>
              <input type="number" id="rc-hours" value="40" min="1" max="168" step="1" />
            </div>
          </div>

          <div class="rc-field-row">
            <div class="rc-field">
              <label for="rc-rate">Vollkostensatz Arbeit</label>
              <div class="rc-input-unit">
                <input type="number" id="rc-rate" value="75" min="10" max="500" step="5" />
                <span class="rc-unit">$ / Std.</span>
              </div>
            </div>
            <div class="rc-field">
              <label for="rc-arc">Lichtbogenzeit</label>
              <div class="rc-input-unit">
                <input type="number" id="rc-arc" value="30" min="5" max="80" step="5" />
                <span class="rc-unit">%</span>
              </div>
            </div>
          </div>

          <div class="rc-field-row">
            <div class="rc-field">
              <label for="rc-rework">Aktuelle Nacharbeitsquote</label>
              <div class="rc-input-unit">
                <input type="number" id="rc-rework" value="5" min="0" max="50" step="1" />
                <span class="rc-unit">%</span>
              </div>
            </div>
            <div class="rc-field">
              <label for="rc-investment">TIP TIG Systeminvestition</label>
              <div class="rc-input-unit">
                <input type="number" id="rc-investment" value="15000" min="5000" max="200000" step="1000" />
                <span class="rc-unit">$</span>
              </div>
            </div>
          </div>

          <div class="rc-note">
            Passen Sie die Werte an Ihren Betrieb an. Die Ergebnisse aktualisieren sich in Echtzeit.
          </div>
        </div>

        <!-- Ergebniskarte -->
        <div class="rc-results-card reveal reveal-delay-1">
          <div class="rc-card-header">
            <TrendingUp size={20} />
            <h2>Ihr TIP TIG ROI</h2>
          </div>

          <!-- Break-Even -->
          <div class="rc-hero-stat">
            <div class="rc-hero-value" id="rc-weeks">&mdash;</div>
            <div class="rc-hero-label">Wochen bis Break-Even</div>
            <div class="rc-progress-bar">
              <div class="rc-progress-fill" id="rc-progress"></div>
            </div>
          </div>

          <!-- Statistiken -->
          <div class="rc-stats-grid">
            <div class="rc-stat">
              <div class="rc-stat-icon"><DollarSign size={18} /></div>
              <div class="rc-stat-value" id="rc-annual">&mdash;</div>
              <div class="rc-stat-label">Jährliche Einsparung</div>
            </div>
            <div class="rc-stat">
              <div class="rc-stat-icon"><Clock size={18} /></div>
              <div class="rc-stat-value" id="rc-hours-saved">&mdash;</div>
              <div class="rc-stat-label">Stunden gespart / Jahr</div>
            </div>
            <div class="rc-stat">
              <div class="rc-stat-icon"><TrendingUp size={18} /></div>
              <div class="rc-stat-value" id="rc-weekly">&mdash;</div>
              <div class="rc-stat-label">Wöchentliche Einsparung</div>
            </div>
            <div class="rc-stat">
              <div class="rc-stat-icon"><Calculator size={18} /></div>
              <div class="rc-stat-value" id="rc-year3">&mdash;</div>
              <div class="rc-stat-label">3-Jahres-Nettoertrag</div>
            </div>
          </div>

          <!-- Aufschlüsselung -->
          <div class="rc-breakdown">
            <h3>So setzt es sich zusammen</h3>
            <div class="rc-breakdown-row">
              <span>Geschwindigkeitsvorteil gegenüber aktuellem Verfahren</span>
              <span class="rc-breakdown-val" id="rc-speed-gain">&mdash;</span>
            </div>
            <div class="rc-breakdown-row">
              <span>Nacharbeitsreduktion (TIP TIG Durchschn. &lt;1&nbsp;%)</span>
              <span class="rc-breakdown-val" id="rc-rework-save">&mdash;</span>
            </div>
            <div class="rc-breakdown-row">
              <span>Arbeitskosteneinsparung pro Woche</span>
              <span class="rc-breakdown-val" id="rc-labor-save">&mdash;</span>
            </div>
            <div class="rc-breakdown-row rc-breakdown-total">
              <span>Gesamteinsparung pro Woche</span>
              <span class="rc-breakdown-val" id="rc-total-weekly">&mdash;</span>
            </div>
          </div>

          <a href="/de/contact" class="rc-cta">Individuelles Angebot anfordern &rarr;</a>
        </div>

      </div>

      <!-- Berechnungsgrundlage -->
      <div class="rc-assumptions reveal">
        <h3>Berechnungsgrundlage</h3>
        <p>
          Geschwindigkeitsfaktoren: WIG &rarr; TIP TIG = 3&times; schneller | MIG &rarr; TIP TIG = 1,5&times; (bei höherer Qualität) |
          Stabelektrode &rarr; TIP TIG = 4&times; schneller | Fülldraht &rarr; TIP TIG = 1,3&times; (bei weniger Nacharbeit).
          TIP TIG Nacharbeitsquote angenommen mit 1&nbsp;%. Alle Angaben sind Schätzwerte —
          <a href="/de/contact">kontaktieren Sie uns</a> für eine detaillierte Analyse auf Basis Ihrer konkreten Anwendung.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .rc-hero {
    position: relative;
    padding: 160px 60px 80px;
    overflow: hidden;
  }
  .rc-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--bg) 0%, white 100%);
    z-index: 0;
  }
  .rc-hero .inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  .rc-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rc-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }
  h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 18px;
  }
  .blue { color: var(--sapphire); }
  .rc-desc {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 500px;
    font-weight: 300;
  }

  /* Calculator Section */
  .rc-calc {
    padding: 0 60px 96px;
  }
  .rc-calc .inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .rc-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  /* Cards */
  .rc-input-card,
  .rc-results-card {
    background: white;
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 32px;
  }
  .rc-results-card {
    background: var(--sapphire);
    border-color: var(--sapphire);
    color: white;
  }
  .rc-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }
  .rc-card-header h2 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    margin: 0;
  }
  .rc-input-card .rc-card-header {
    color: var(--black);
  }

  /* Input Fields */
  .rc-field {
    margin-bottom: 18px;
  }
  .rc-field label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gray-mid);
    margin-bottom: 6px;
  }
  .rc-field input,
  .rc-field select {
    width: 100%;
    padding: 11px 14px;
    font-size: 0.95rem;
    font-family: 'Inter', sans-serif;
    border: 1.5px solid var(--gray-light);
    border-radius: 8px;
    background: var(--bg);
    color: var(--black);
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .rc-field input:focus,
  .rc-field select:focus {
    outline: none;
    border-color: var(--sapphire);
  }
  .rc-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .rc-input-unit {
    position: relative;
  }
  .rc-input-unit input {
    padding-right: 52px;
  }
  .rc-unit {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--gray-mid);
    pointer-events: none;
  }
  .rc-note {
    font-size: 0.8rem;
    color: var(--gray-mid);
    font-weight: 300;
    margin-top: 8px;
    font-style: italic;
  }

  /* Hero Stat */
  .rc-hero-stat {
    text-align: center;
    margin-bottom: 28px;
  }
  .rc-hero-value {
    font-family: 'Manrope', sans-serif;
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 4px;
  }
  .rc-hero-label {
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0.75;
    margin-bottom: 16px;
  }
  .rc-progress-bar {
    height: 6px;
    background: rgba(255,255,255,0.15);
    border-radius: 3px;
    overflow: hidden;
    max-width: 280px;
    margin: 0 auto;
  }
  .rc-progress-fill {
    height: 100%;
    background: white;
    border-radius: 3px;
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    width: 0;
  }

  /* Stats Grid */
  .rc-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 28px;
  }
  .rc-stat {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 16px;
    text-align: center;
  }
  .rc-stat-icon {
    opacity: 0.5;
    margin-bottom: 6px;
  }
  .rc-stat-value {
    font-family: 'Manrope', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .rc-stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Breakdown */
  .rc-breakdown {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: 20px;
    margin-bottom: 24px;
  }
  .rc-breakdown h3 {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.6;
    margin-bottom: 12px;
  }
  .rc-breakdown-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-size: 0.88rem;
    font-weight: 300;
    opacity: 0.85;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .rc-breakdown-row:last-child {
    border-bottom: none;
  }
  .rc-breakdown-val {
    font-weight: 600;
    font-family: 'Manrope', sans-serif;
  }
  .rc-breakdown-total {
    opacity: 1;
    font-weight: 600;
    font-size: 0.95rem;
    border-top: 1px solid rgba(255,255,255,0.2);
    margin-top: 4px;
    padding-top: 12px;
  }

  /* CTA */
  .rc-cta {
    display: block;
    text-align: center;
    padding: 14px;
    background: white;
    color: var(--sapphire);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s;
  }
  .rc-cta:hover {
    background: var(--bg);
    transform: translateY(-1px);
  }

  /* Assumptions */
  .rc-assumptions {
    margin-top: 40px;
    padding: 24px;
    background: var(--bg);
    border-radius: 10px;
  }
  .rc-assumptions h3 {
    font-family: 'Manrope', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-mid);
    margin-bottom: 8px;
  }
  .rc-assumptions p {
    font-size: 0.85rem;
    color: var(--gray-mid);
    line-height: 1.75;
    font-weight: 300;
  }
  .rc-assumptions a {
    color: var(--sapphire);
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .rc-hero { padding: 120px 24px 56px; }
    .rc-calc { padding: 0 24px 72px; }
    .rc-layout { grid-template-columns: 1fr; }
    .rc-field-row { grid-template-columns: 1fr; }
    .rc-hero-value { font-size: 3rem; }
  }
</style>

<script>
  function initROI() {
    const $ = (id: string) => document.getElementById(id);

    const els = {
      process: $('rc-process') as HTMLSelectElement,
      welders: $('rc-welders') as HTMLInputElement,
      hours: $('rc-hours') as HTMLInputElement,
      rate: $('rc-rate') as HTMLInputElement,
      arc: $('rc-arc') as HTMLInputElement,
      rework: $('rc-rework') as HTMLInputElement,
      investment: $('rc-investment') as HTMLInputElement,
    };

    if (!els.process) return;

    // Speed multipliers: how much faster TIP TIG is vs. current process
    const speedFactors: Record<string, number> = {
      tig: 3.0,
      mig: 1.5,
      stick: 4.0,
      fcaw: 1.3,
    };

    function calc() {
      const process = els.process.value;
      const welders = Math.max(1, Number(els.welders.value) || 1);
      const hoursWeek = Math.max(1, Number(els.hours.value) || 40);
      const laborRate = Math.max(10, Number(els.rate.value) || 75);
      const arcPct = Math.max(5, Number(els.arc.value) || 30) / 100;
      const reworkPct = Math.max(0, Number(els.rework.value) || 5) / 100;
      const investment = Math.max(1000, Number(els.investment.value) || 15000);

      const speedFactor = speedFactors[process] || 3.0;
      const tiptigRework = 0.01; // TIP TIG avg rework rate

      // Actual welding hours per week per welder
      const arcHoursWeek = hoursWeek * arcPct;

      // Time savings from speed: if 3x faster, you save 2/3 of arc time
      const timeSavingsFactor = 1 - (1 / speedFactor);
      const hoursSavedWeek = arcHoursWeek * timeSavingsFactor * welders;
      const laborSaveWeek = hoursSavedWeek * laborRate;

      // Rework savings
      const reworkReduction = reworkPct - tiptigRework;
      const reworkHoursWeek = hoursWeek * reworkPct * welders;
      const reworkSavedHours = reworkHoursWeek * (reworkReduction / reworkPct);
      const reworkSaveWeek = reworkSavedHours > 0 ? reworkSavedHours * laborRate : 0;

      // Totals
      const totalWeeklySave = laborSaveWeek + reworkSaveWeek;
      const weeksROI = totalWeeklySave > 0 ? investment / totalWeeklySave : 999;
      const annualSave = totalWeeklySave * 52;
      const hoursSavedYear = (hoursSavedWeek + (reworkSavedHours > 0 ? reworkSavedHours : 0)) * 52;
      const year3Return = annualSave * 3 - investment;

      // Update DOM
      const fmt = (n: number) => n >= 1000 ? '$' + Math.round(n).toLocaleString('en-US') : '$' + Math.round(n);

      ($('rc-weeks') as HTMLElement).textContent = weeksROI < 999 ? weeksROI.toFixed(1) : '\u2014';
      ($('rc-annual') as HTMLElement).textContent = fmt(annualSave);
      ($('rc-hours-saved') as HTMLElement).textContent = Math.round(hoursSavedYear).toLocaleString('en-US');
      ($('rc-weekly') as HTMLElement).textContent = fmt(totalWeeklySave);
      ($('rc-year3') as HTMLElement).textContent = fmt(year3Return);

      ($('rc-speed-gain') as HTMLElement).textContent = speedFactor + '\u00d7 schneller';
      ($('rc-rework-save') as HTMLElement).textContent = fmt(reworkSaveWeek) + '/Wo.';
      ($('rc-labor-save') as HTMLElement).textContent = fmt(laborSaveWeek) + '/Wo.';
      ($('rc-total-weekly') as HTMLElement).textContent = fmt(totalWeeklySave) + '/Wo.';

      // Progress bar: map weeks to percentage (52 weeks = 0%, 1 week = 100%)
      const pct = weeksROI < 999 ? Math.max(5, Math.min(100, (1 - weeksROI / 52) * 100)) : 0;
      ($('rc-progress') as HTMLElement).style.width = pct + '%';
    }

    // Bind all inputs
    Object.values(els).forEach(el => {
      el.addEventListener('input', calc);
      el.addEventListener('change', calc);
    });

    // Initial calc
    calc();
  }

  initROI();
  document.addEventListener('astro:page-load', initROI);
</script>
