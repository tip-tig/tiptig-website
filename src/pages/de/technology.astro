import TechHero from '../../components/technology/TechHero.astro';
import HotWire from '../../components/technology/HotWire.astro';
import WireDynamics from '../../components/technology/WireDynamics.astro';
import DepositionChart from '../../components/technology/DepositionChart.astro';
import ProcessComparison from '../../components/technology/ProcessComparison.astro';
import HeatInput from '../../components/technology/HeatInput.astro';
import TechVideo from '../../components/technology/TechVideo.astro';
import CTA from '../../components/home/CTA.astro';
---

<BaseLayout
  title="TIP TIG Schweißverfahren — Dynamische Drahtvorschub-Technologie"
  description="Erfahren Sie, wie das TIP TIG Heißdraht-WIG-Schweißverfahren mit dynamischem Drahtvorschub 12x höhere Abschmelzleistung, geringstmöglichen Wärmeeintrag und überlegene Fusionsqualität liefert."
