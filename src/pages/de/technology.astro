>
  <div id="tech-page" data-units="metric">
    <TechHero lang="de" />
    <TechVideo lang="de" />
    <HotWire lang="de" />
    <WireDynamics lang="de" />
    <DepositionChart lang="de" />
    <ProcessComparison lang="de" />
    <HeatInput lang="de" />
    <CTA lang="de" />
  </div>
</BaseLayout>

<style is:global>
  #tech-page .u-imp { display: none !important; }
  #tech-page #unit-toggle { display: none !important; }
</style>
