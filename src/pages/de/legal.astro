---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowLeft } from '@lucide/astro';
---

<BaseLayout
  lang="de"
  title="Impressum — TIP TIG"
  description="Impressum von tiptig.com — Unternehmensinformationen, UID-Nummer, Aufsichtsbehörde und Haftungshinweise gemäß ECG §5, MedienG §25."
>
  <section class="lg-hero">
    <div class="lg-hero-bg"></div>
    <div class="inner">
      <div class="lg-eyebrow">Impressum</div>
      <h1>Impressum</h1>
      <p class="lg-desc">
        Informationen gemäß §&nbsp;5 E-Commerce-Gesetz (ECG),
        §&nbsp;25 Mediengesetz (MedienG) und §&nbsp;63 Gewerbeordnung (GewO).
      </p>
    </div>
  </section>

  <section class="lg-content">
    <div class="inner-lg">

      <!-- Unternehmensinformationen -->
      <div class="lg-section reveal">
        <h2>Unternehmensinformationen</h2>
        <div class="lg-info-grid">
          <div class="lg-info-item">
            <h3>Geschäftsinhaber &amp; Betreiber</h3>
            <p>Ing. Siegfried Plasch</p>
          </div>
          <div class="lg-info-item">
            <h3>Geschäftsadresse</h3>
            <p>Baumayrweg 4<br>4631 Krenglbach<br>Österreich</p>
          </div>
          <div class="lg-info-item">
            <h3>Kontakt</h3>
            <p>
              Telefon: <a href="tel:+43720303500">+43 720 303500</a><br>
              E-Mail: <a href="mailto:office@tiptig.com">office@tiptig.com</a>
            </p>
          </div>
          <div class="lg-info-item">
            <h3>Unternehmensform</h3>
            <p>Einzelunternehmen (e.U.)<br>
            Gewerbliche Tätigkeit, ausgenommen reglementierte Gewerbe; keine Handelsvermittlung</p>
          </div>
        </div>
      </div>

      <!-- Registrierung & Steuern -->
      <div class="lg-section reveal">
        <h2>Registrierung &amp; Steuerinformationen</h2>
        <div class="lg-info-grid">
          <div class="lg-info-item">
            <h3>UID-Nummer</h3>
            <p>ATU40074600</p>
          </div>
          <div class="lg-info-item">
            <h3>GISA-Nummer</h3>
            <p>17436113</p>
          </div>
          <div class="lg-info-item">
            <h3>Zuständige Behörde</h3>
            <p>Bezirkshauptmannschaft Wels-Land</p>
          </div>
          <div class="lg-info-item">
            <h3>Berufsvertretung</h3>
            <p>Mitglied der Wirtschaftskammer Oberösterreich</p>
          </div>
        </div>
      </div>

      <!-- Offenlegung gem. MedienG -->
      <div class="lg-section reveal">
        <h2>Offenlegung gemäß §&nbsp;25 Mediengesetz (MedienG)</h2>
        <div class="lg-text">
          <p><strong>Medieninhaber:</strong> Ing. Siegfried Plasch, Baumayrweg 4, 4631 Krenglbach, Österreich</p>
          <p><strong>Grundlegende Richtung:</strong> Informationen über TIP TIG Schweißtechnologie, Produkte und Dienstleistungen.</p>
        </div>
      </div>

      <!-- Anwendbare Vorschriften -->
      <div class="lg-section reveal">
        <h2>Anwendbare Rechtsvorschriften</h2>
        <div class="lg-text">
          <p>Gewerbeordnung (GewO 1994), abrufbar unter
            <a href="https://www.ris.bka.gv.at" target="_blank" rel="noopener noreferrer">ris.bka.gv.at</a>.
          </p>
        </div>
      </div>

      <!-- Haftungsausschluss -->
      <div class="lg-section reveal">
        <h2>Haftungsausschluss</h2>
        <div class="lg-text">
          <p>
            Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt.
            Für die Richtigkeit, Vollständigkeit und Aktualität der bereitgestellten
            Informationen wird jedoch keine Gewähr übernommen. Die Haftung für Schäden,
            die direkt oder indirekt aus der Nutzung dieser Website entstehen, wird im
            gesetzlich zulässigen Umfang ausgeschlossen.
          </p>
          <p>
            Diese Einschränkung gilt nicht, soweit zwingende gesetzliche Bestimmungen
            eine Haftung vorsehen — insbesondere bei Vorsatz, grober Fahrlässigkeit,
            Personenschäden oder Haftung nach dem Produkthaftungsgesetz (PHG).
          </p>
        </div>
      </div>

      <!-- Externe Links -->
      <div class="lg-section reveal">
        <h2>Externe Links</h2>
        <div class="lg-text">
          <p>
            Diese Website enthält Links zu Websites Dritter. Diese externen Seiten unterliegen
            nicht unserer Kontrolle, und wir übernehmen keine Verantwortung für deren Inhalte.
            Zum Zeitpunkt der Verlinkung waren auf den verlinkten Seiten keine rechtswidrigen
            Inhalte erkennbar. Sollte ein Rechtsverstoß bekannt werden, werden entsprechende
            Links unverzüglich entfernt.
          </p>
        </div>
      </div>

      <!-- Urheberrecht -->
      <div class="lg-section reveal">
        <h2>Urheberrecht</h2>
        <div class="lg-text">
          <p>
            Alle auf dieser Website veröffentlichten Inhalte — einschließlich Texte, Bilder,
            Grafiken und Design — sind urheberrechtlich geschützt. Jede Vervielfältigung,
            Verbreitung oder Nutzung über den Rahmen des Urheberrechts hinaus bedarf der
            vorherigen schriftlichen Zustimmung von Ing. Siegfried Plasch. TIP TIG ist eine
            eingetragene Marke.
          </p>
        </div>
      </div>

      <!-- B2B-Hinweis -->
      <div class="lg-section reveal">
        <h2>Geschäftskundenverkauf (B2B)</h2>
        <div class="lg-text">
          <p>
            Unsere Produkte und Dienstleistungen richten sich ausschließlich an Geschäftskunden (B2B).
            Wir sind weder verpflichtet noch bereit, an Streitbeilegungsverfahren vor einer
            Verbraucherschlichtungsstelle gemäß dem Alternative-Streitbeilegung-Gesetz (AStG)
            teilzunehmen.
          </p>
        </div>
      </div>

      <!-- EU-Streitschlichtung -->
      <div class="lg-section reveal">
        <h2>Online-Streitbeilegung</h2>
        <div class="lg-text">
          <p>
            Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
            <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">ec.europa.eu/consumers/odr</a>.
            Da wir nicht an Verbraucher verkaufen, nehmen wir nicht an OS-Verfahren teil.
          </p>
        </div>
      </div>

      <!-- Anwendbares Recht & Gerichtsstand -->
      <div class="lg-section lg-section-last reveal">
        <h2>Anwendbares Recht &amp; Gerichtsstand</h2>
        <div class="lg-text">
          <p>
            Dieses Impressum und alle Angelegenheiten im Zusammenhang mit der Nutzung dieser
            Website unterliegen österreichischem Recht unter Ausschluss der
            Kollisionsnormen und des UN-Kaufrechts (CISG).
            Ausschließlicher Gerichtsstand ist Wels, Österreich.
          </p>
          <p class="lg-updated">Zuletzt aktualisiert: März 2026. Im Falle von Abweichungen ist die deutschsprachige Fassung dieses Impressums maßgeblich.</p>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .lg-hero {
    position: relative;
    padding: 160px 60px 80px;
    overflow: hidden;
  }
  .lg-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--bg) 0%, white 100%);
    z-index: 0;
  }
  .lg-hero .inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  .lg-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .lg-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }
  h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 18px;
  }
  .blue { color: var(--sapphire); }
  .lg-desc {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 600px;
    font-weight: 300;
  }

  /* Content */
  .lg-content {
    padding: 0 60px 96px;
  }
  .inner-lg {
    max-width: 860px;
  }

  .lg-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--gray-light);
  }
  .lg-section-last {
    border-bottom: none;
  }

  .lg-section h2 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--black);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  /* Info Grid (2 cols) */
  .lg-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 48px;
  }
  .lg-info-item h3 {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 6px;
  }
  .lg-info-item p {
    font-size: 0.95rem;
    color: var(--gray-mid);
    line-height: 1.7;
    font-weight: 400;
  }

  /* Text blocks */
  .lg-text p {
    font-size: 0.95rem;
    color: var(--gray-mid);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 14px;
  }
  .lg-text p:last-child {
    margin-bottom: 0;
  }
  .lg-text p strong {
    font-weight: 600;
    color: var(--black);
  }

  /* Links */
  .lg-text a,
  .lg-info-item a {
    color: var(--sapphire);
    text-decoration: none;
    transition: color 0.2s;
  }
  .lg-text a:hover,
  .lg-info-item a:hover {
    color: var(--sapphire-light);
  }

  .lg-updated {
    font-size: 0.85rem !important;
    font-style: italic;
    color: rgba(107, 114, 128, 0.7) !important;
    margin-top: 8px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .lg-hero { padding: 120px 24px 56px; }
    .lg-content { padding: 0 24px 72px; }
    .lg-info-grid { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
