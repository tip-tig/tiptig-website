---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CladdingHero from '../../components/cladding/CladdingHero.astro';
import CladdingIntro from '../../components/cladding/CladdingIntro.astro';
import CladdingVideo from '../../components/cladding/CladdingVideo.astro';
import CladdingBenefits from '../../components/cladding/CladdingBenefits.astro';
import CladdingApplications from '../../components/cladding/CladdingApplications.astro';
import CladdingDeposition from '../../components/cladding/CladdingDeposition.astro';
import CTA from '../../components/home/CTA.astro';
---

<BaseLayout
  title="TIP TIG TwinWire RapidClad 2.0 — Auftragschweißen"
  description="TIP TIG TwinWire RapidClad 2.0 liefert bis zu 9,1 kg/h Abschmelzleistung bei 80 % reduzierter Aufmischung — der höchste Standard im Auftragschweißen."
  lang="de"
>
  <div id="cl-page" data-units="metric">
    <CladdingHero lang="de" />
    <CladdingIntro lang="de" />
    <CladdingVideo lang="de" />
    <CladdingBenefits lang="de" />
    <CladdingApplications lang="de" />
    <CladdingDeposition lang="de" />
    <CTA lang="de" />
  </div>
</BaseLayout>

<style is:global>
  #cl-page .u-imp { display: none !important; }
  #cl-page #unit-toggle { display: none !important; }
</style>
