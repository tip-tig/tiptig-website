---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KeyholeHero from '../../components/keyhole/KeyholeHero.astro';
import KeyholeIntro from '../../components/keyhole/KeyholeIntro.astro';
import KeyholeVideo from '../../components/keyhole/KeyholeVideo.astro';
import KeyholeBenefits from '../../components/keyhole/KeyholeBenefits.astro';
import KeyholeMaterials from '../../components/keyhole/KeyholeMaterials.astro';
import KeyholeComparison from '../../components/keyhole/KeyholeComparison.astro';
import KeyholeCost from '../../components/keyhole/KeyholeCost.astro';
import CTA from '../../components/home/CTA.astro';
---

<BaseLayout
  title="TIP TIG focus — Keyhole-WIG-Schweißen"
  description="TIP TIG focus liefert Volldurchschweißung in einer Lage bis 12 mm — 600 % schneller als WIG, 80 % Kosteneinsparung, mit röntgenqualitätssicheren Ergebnissen."
  lang="de"
>
  <div id="kh-page" data-units="metric">
    <KeyholeHero lang="de" />
    <KeyholeIntro lang="de" />
    <KeyholeVideo lang="de" />
    <KeyholeBenefits lang="de" />
    <KeyholeMaterials lang="de" />
    <KeyholeComparison lang="de" />
    <KeyholeCost lang="de" />
    <CTA lang="de" />
  </div>
</BaseLayout>

<style is:global>
  #kh-page .u-imp { display: none !important; }
  #kh-page #unit-toggle { display: none !important; }
</style>
