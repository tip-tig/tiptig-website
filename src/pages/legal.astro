---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowLeft } from '@lucide/astro';
---

<BaseLayout
  title="Legal Notice / Impressum — TIP TIG"
  description="Legal notice (Impressum) for tiptig.com — company information, VAT ID, regulatory authority, and liability disclosures as required by Austrian law (ECG §5, MedienG §25)."
>
  <section class="lg-hero">
    <div class="lg-hero-bg"></div>
    <div class="inner">
      <div class="lg-eyebrow">Impressum</div>
      <h1>Legal<br><span class="blue">Notice</span></h1>
      <p class="lg-desc">
        Information pursuant to §&nbsp;5 E-Commerce Act (ECG),
        §&nbsp;25 Media Act (MedienG), and §&nbsp;63 Trade Regulation Act (GewO).
      </p>
    </div>
  </section>

  <section class="lg-content">
    <div class="inner-lg">

      <!-- Company Information -->
      <div class="lg-section reveal">
        <h2>Company Information</h2>
        <div class="lg-info-grid">
          <div class="lg-info-item">
            <h3>Business Owner &amp; Operator</h3>
            <p>Ing. Siegfried Plasch</p>
          </div>
          <div class="lg-info-item">
            <h3>Business Address</h3>
            <p>Baumayrweg 4<br>4631 Krenglbach<br>Austria</p>
          </div>
          <div class="lg-info-item">
            <h3>Contact</h3>
            <p>
              Phone: <a href="tel:+43720303500">+43 720 303500</a><br>
              Email: <a href="mailto:office@tiptig.com">office@tiptig.com</a>
            </p>
          </div>
          <div class="lg-info-item">
            <h3>Business Type</h3>
            <p>Sole proprietorship (Einzelunternehmen)<br>
            Commercial trade (Gewerbliche Tätigkeit), excluding regulated trades; no trade agent activity</p>
          </div>
        </div>
      </div>

      <!-- Registration & Tax -->
      <div class="lg-section reveal">
        <h2>Registration &amp; Tax Information</h2>
        <div class="lg-info-grid">
          <div class="lg-info-item">
            <h3>VAT Identification Number</h3>
            <p>ATU40074600</p>
          </div>
          <div class="lg-info-item">
            <h3>GISA Number</h3>
            <p>17436113</p>
          </div>
          <div class="lg-info-item">
            <h3>Competent Authority</h3>
            <p>District Authority Wels-Land<br>(Bezirkshauptmannschaft Wels-Land)</p>
          </div>
          <div class="lg-info-item">
            <h3>Professional Chamber</h3>
            <p>Member of the Upper Austrian Economic Chamber<br>(Wirtschaftskammer Oberösterreich)</p>
          </div>
        </div>
      </div>

      <!-- Media Act Disclosure -->
      <div class="lg-section reveal">
        <h2>Disclosure pursuant to §&nbsp;25 Media Act (MedienG)</h2>
        <div class="lg-text">
          <p><strong>Media Owner:</strong> Ing. Siegfried Plasch, Baumayrweg 4, 4631 Krenglbach, Austria</p>
          <p><strong>Basic Orientation:</strong> Information on TIP TIG welding technology, products, and services.</p>
        </div>
      </div>

      <!-- Applicable Law -->
      <div class="lg-section reveal">
        <h2>Applicable Regulatory Provisions</h2>
        <div class="lg-text">
          <p>Trade Regulation Act (Gewerbeordnung — GewO 1994), accessible at
            <a href="https://www.ris.bka.gv.at" target="_blank" rel="noopener noreferrer">ris.bka.gv.at</a>.
          </p>
        </div>
      </div>

      <!-- Liability -->
      <div class="lg-section reveal">
        <h2>Liability Disclaimer</h2>
        <div class="lg-text">
          <p>
            The contents of this website have been prepared with the utmost care.
            However, no warranty or guarantee is provided as to the accuracy, completeness,
            or timeliness of the information presented. Liability for damages arising directly
            or indirectly from the use of this website is excluded to the extent permitted by law.
          </p>
          <p>
            This limitation does not apply where mandatory statutory provisions require liability —
            in particular in cases of intent, gross negligence, personal injury,
            or liability under the Austrian Product Liability Act (Produkthaftungsgesetz — PHG).
          </p>
        </div>
      </div>

      <!-- External Links -->
      <div class="lg-section reveal">
        <h2>External Links</h2>
        <div class="lg-text">
          <p>
            This website contains links to third-party websites. These external sites are not under our control,
            and we assume no responsibility for their content. At the time of linking, no unlawful content was
            identifiable on the linked pages. Should any legal infringement become known, such links will
            be removed without delay.
          </p>
        </div>
      </div>

      <!-- Copyright -->
      <div class="lg-section reveal">
        <h2>Copyright</h2>
        <div class="lg-text">
          <p>
            All content published on this website — including text, images, graphics,
            and design — is protected by copyright. Any reproduction, distribution, or
            use beyond the scope of copyright law requires prior written consent from
            Ing. Siegfried Plasch. TIP TIG is a registered trademark.
          </p>
        </div>
      </div>

      <!-- B2B Notice -->
      <div class="lg-section reveal">
        <h2>Business-to-Business Sales</h2>
        <div class="lg-text">
          <p>
            Our products and services are directed exclusively at business customers (B2B).
            We are neither obliged nor willing to participate in dispute resolution procedures
            before a consumer arbitration board pursuant to the Austrian Alternative Dispute
            Resolution Act (AStG).
          </p>
        </div>
      </div>

      <!-- EU ODR -->
      <div class="lg-section reveal">
        <h2>Online Dispute Resolution</h2>
        <div class="lg-text">
          <p>
            The European Commission provides an Online Dispute Resolution (ODR) platform at
            <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">ec.europa.eu/consumers/odr</a>.
            As we do not sell to consumers, we do not participate in ODR proceedings.
          </p>
        </div>
      </div>

      <!-- Governing Law -->
      <div class="lg-section lg-section-last reveal">
        <h2>Governing Law &amp; Jurisdiction</h2>
        <div class="lg-text">
          <p>
            This legal notice and all matters arising from the use of this website are governed
            by Austrian law, excluding its conflict-of-laws provisions and the United Nations
            Convention on Contracts for the International Sale of Goods (CISG).
            The exclusive place of jurisdiction is Wels, Austria.
          </p>
          <p class="lg-updated">Last updated: March 2026. The German-language version of this legal notice shall prevail in case of discrepancies.</p>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .lg-hero {
    position: relative;
    padding: 160px 60px 80px;
    overflow: hidden;
  }
  .lg-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--bg) 0%, white 100%);
    z-index: 0;
  }
  .lg-hero .inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  .lg-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .lg-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }
  h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 18px;
  }
  .blue { color: var(--sapphire); }
  .lg-desc {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 600px;
    font-weight: 300;
  }

  /* Content */
  .lg-content {
    padding: 0 60px 96px;
  }
  .inner-lg {
    max-width: 860px;
  }

  .lg-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--gray-light);
  }
  .lg-section-last {
    border-bottom: none;
  }

  .lg-section h2 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--black);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  /* Info Grid (2 cols) */
  .lg-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 48px;
  }
  .lg-info-item h3 {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 6px;
  }
  .lg-info-item p {
    font-size: 0.95rem;
    color: var(--gray-mid);
    line-height: 1.7;
    font-weight: 400;
  }

  /* Text blocks */
  .lg-text p {
    font-size: 0.95rem;
    color: var(--gray-mid);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 14px;
  }
  .lg-text p:last-child {
    margin-bottom: 0;
  }
  .lg-text p strong {
    font-weight: 600;
    color: var(--black);
  }

  /* Links */
  .lg-text a,
  .lg-info-item a {
    color: var(--sapphire);
    text-decoration: none;
    transition: color 0.2s;
  }
  .lg-text a:hover,
  .lg-info-item a:hover {
    color: var(--sapphire-light);
  }

  .lg-updated {
    font-size: 0.85rem !important;
    font-style: italic;
    color: rgba(107, 114, 128, 0.7) !important;
    margin-top: 8px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .lg-hero { padding: 120px 24px 56px; }
    .lg-content { padding: 0 24px 72px; }
    .lg-info-grid { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
