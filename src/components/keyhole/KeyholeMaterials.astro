---
import { Factory, Cylinder, Wind, Pipette, Cog, Snowflake } from '@lucide/astro';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const materialKeys = [
  'kh.mat.m1', 'kh.mat.m2', 'kh.mat.m3', 'kh.mat.m4', 'kh.mat.m5', 'kh.mat.m6',
  'kh.mat.m7', 'kh.mat.m8', 'kh.mat.m9', 'kh.mat.m10', 'kh.mat.m11', 'kh.mat.m12',
];

const applications = [
  { icon: 'Cylinder', titleKey: 'kh.mat.app1' },
  { icon: 'Pipette', titleKey: 'kh.mat.app2' },
  { icon: 'Wind', titleKey: 'kh.mat.app3' },
  { icon: 'Factory', titleKey: 'kh.mat.app4' },
  { icon: 'Cog', titleKey: 'kh.mat.app5' },
  { icon: 'Snowflake', titleKey: 'kh.mat.app6' },
];

const appIconMap: Record<string, any> = { Factory, Cylinder, Wind, Pipette, Cog, Snowflake };
---

<section class="kh-materials">
  <div class="inner">
    <div class="kh-mat-grid">
      <div class="kh-mat-left">
        <div class="section-eyebrow reveal">{t('kh.mat.eyebrow')}</div>
        <h2 class="section-title reveal">{t('kh.mat.title')}<br>{t('kh.mat.title2')}</h2>
        <div class="mat-tags reveal">
          {materialKeys.map((key) => (
            <span class="mat-tag">{t(key)}</span>
          ))}
        </div>
      </div>

      <div class="kh-mat-right">
        <div class="section-eyebrow reveal">{t('kh.mat.app.eyebrow')}</div>
        <h2 class="section-title reveal">{t('kh.mat.app.title')}<br>{t('kh.mat.app.title2')}</h2>
        <div class="app-list reveal">
          {applications.map((app) => {
            const Icon = appIconMap[app.icon];
            return (
              <div class="app-item">
                <div class="app-icon"><Icon size={20} /></div>
                <span>{t(app.titleKey)}</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .kh-materials {
    padding: 110px 60px;
    background: var(--bg);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .kh-mat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 24px;
  }

  /* Material tags */
  .mat-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .mat-tag {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--sapphire);
    background: var(--white);
    border: 1px solid var(--sapphire-mid);
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .mat-tag:hover {
    background: var(--sapphire);
    color: white;
    border-color: var(--sapphire);
  }

  /* Application list */
  .app-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .app-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 10px;
    transition: all 0.2s;
  }

  .app-item:hover {
    border-color: var(--sapphire-mid);
    transform: translateX(4px);
  }

  .app-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    background: var(--sapphire-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
  }

  .app-item span {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--black);
  }

  @media (max-width: 960px) {
    .kh-materials { padding: 72px 24px; }
    .kh-mat-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }
</style>
