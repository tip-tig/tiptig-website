---
import { Factory, Cylinder, Wind, Pipette, Cog, Snowflake } from '@lucide/astro';

const materials = [
  'Low Alloy Steel',
  'Medium Alloy Steel',
  'High Alloy Steel',
  'Duplex',
  'Super Duplex',
  'Copper',
  'Titanium',
  'Aluminum',
  '9% Nickel Steel',
  'Heat-Resistant Alloys',
  'Galvanized Materials',
  'Coated Materials',
];

const applications = [
  { icon: 'Cylinder', title: 'Vessel & Tank Construction' },
  { icon: 'Pipette', title: 'Continuous Pipe Production' },
  { icon: 'Wind', title: 'Turbine Production' },
  { icon: 'Factory', title: 'Pipeline Construction' },
  { icon: 'Cog', title: 'Special Machine Construction' },
  { icon: 'Snowflake', title: 'LNG & Cryogenic' },
];

const appIconMap: Record<string, any> = { Factory, Cylinder, Wind, Pipette, Cog, Snowflake };
---

<section class="kh-materials">
  <div class="inner">
    <div class="kh-mat-grid">
      <div class="kh-mat-left">
        <div class="section-eyebrow reveal">Compatibility</div>
        <h2 class="section-title reveal">Works With All<br>Major Alloys</h2>
        <div class="mat-tags reveal">
          {materials.map((m) => (
            <span class="mat-tag">{m}</span>
          ))}
        </div>
      </div>

      <div class="kh-mat-right">
        <div class="section-eyebrow reveal">Applications</div>
        <h2 class="section-title reveal">Built for<br>Demanding Industries</h2>
        <div class="app-list reveal">
          {applications.map((app) => {
            const Icon = appIconMap[app.icon];
            return (
              <div class="app-item">
                <div class="app-icon"><Icon size={20} /></div>
                <span>{app.title}</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .kh-materials {
    padding: 110px 60px;
    background: var(--bg);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .kh-mat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 24px;
  }

  /* Material tags */
  .mat-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .mat-tag {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--sapphire);
    background: var(--white);
    border: 1px solid var(--sapphire-mid);
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .mat-tag:hover {
    background: var(--sapphire);
    color: white;
    border-color: var(--sapphire);
  }

  /* Application list */
  .app-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .app-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 10px;
    transition: all 0.2s;
  }

  .app-item:hover {
    border-color: var(--sapphire-mid);
    transform: translateX(4px);
  }

  .app-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    background: var(--sapphire-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
  }

  .app-item span {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--black);
  }

  @media (max-width: 960px) {
    .kh-materials { padding: 72px 24px; }
    .kh-mat-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }
</style>
