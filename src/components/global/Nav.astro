---
import { categories } from '../../data/products';

const productLinks = categories.map(cat => ({
  label: cat.name,
  href: `/products#${cat.slug}`,
}));

const technologyLinks = [
  { label: 'The TIP TIG Process', href: '/technology' },
  { label: 'Keyhole TIG Welding', href: '/keyhole-tig-welding' },
  { label: 'Weld Overlay Cladding', href: '/weld-overlay-cladding' },
];

const industryLinks = [
  { label: 'Aerospace', href: '/industries/aerospace' },
  { label: 'Defense & Naval', href: '/industries/defense' },
  { label: 'Food & Dairy', href: '/industries/food-dairy' },
  { label: 'Heat Exchangers', href: '/industries/heat-exchangers' },
  { label: 'Nuclear', href: '/industries/nuclear' },
  { label: 'Oil & Gas', href: '/industries/oil-gas' },
  { label: 'Petrochemical', href: '/industries/petrochemical' },
  { label: 'Pharmaceutical', href: '/industries/pharma' },
  { label: 'Pipelines', href: '/industries/pipelines' },
  { label: 'Power Generation', href: '/industries/power-generation' },
  { label: 'Shipbuilding', href: '/industries/shipbuilding' },
];

const supportLinks = [
  { label: 'Wire Speed Calculator', href: '/support/wire-speed-calculator' },
  { label: 'Software Updates', href: '/support/software-update' },
  { label: 'Control Panel Guide', href: '/support/control-panel' },
  { label: 'Warranty', href: '/support/warranty' },
  { label: "Owner's Manuals", href: '/support/manuals' },
  { label: 'Service Instructions', href: 'https://repair.tiptig.com', external: true },
];

const companyLinks = [
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<nav>
  <a href="/" class="logo">
    <img src="/images/Logo_fuer_Homepage_24r.svg" alt="TIP TIG" height="36" />
  </a>

  <ul class="nav-links">
    <li class="has-dropdown">
      <a href="/products">Products <span class="dd-arrow">▾</span></a>
      <ul class="dropdown">
        {productLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="has-dropdown">
      <a href="/technology">Technology <span class="dd-arrow">▾</span></a>
      <ul class="dropdown">
        {technologyLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="has-dropdown">
      <a href="/industries">Industries <span class="dd-arrow">▾</span></a>
      <ul class="dropdown">
        {industryLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="has-dropdown">
      <a href="/support">Support <span class="dd-arrow">▾</span></a>
      <ul class="dropdown">
        {supportLinks.map(link => (
          <li><a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="has-dropdown">
      <a href="/about">Company <span class="dd-arrow">▾</span></a>
      <ul class="dropdown">
        {companyLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
  </ul>

  <!-- Mobile Toggle -->
  <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <ul>
    <li class="mobile-dropdown">
      <button class="mobile-dropdown-toggle">Products <span class="dd-arrow">▾</span></button>
      <ul class="mobile-dropdown-list">
        {productLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="mobile-dropdown">
      <button class="mobile-dropdown-toggle">Technology <span class="dd-arrow">▾</span></button>
      <ul class="mobile-dropdown-list">
        {technologyLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="mobile-dropdown">
      <button class="mobile-dropdown-toggle">Industries <span class="dd-arrow">▾</span></button>
      <ul class="mobile-dropdown-list">
        {industryLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="mobile-dropdown">
      <button class="mobile-dropdown-toggle">Support <span class="dd-arrow">▾</span></button>
      <ul class="mobile-dropdown-list">
        {supportLinks.map(link => (
          <li><a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}>{link.label}</a></li>
        ))}
      </ul>
    </li>
    <li class="mobile-dropdown">
      <button class="mobile-dropdown-toggle">Company <span class="dd-arrow">▾</span></button>
      <ul class="mobile-dropdown-list">
        {companyLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </li>
  </ul>
</div>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--gray-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 60px;
    height: 68px;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .logo img {
    height: 68px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gray-mid);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }
  .nav-links a:hover { color: var(--sapphire); }

  /* Dropdown */
  .has-dropdown { position: relative; }
  .dd-arrow { font-size: 0.7em; margin-left: 2px; }
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    padding: 8px 0;
    min-width: 200px;
    z-index: 101;
    list-style: none;
  }
  .has-dropdown:hover .dropdown { display: block; }
  .dropdown li a {
    display: block;
    padding: 8px 20px;
    font-size: 0.84rem;
    font-weight: 400;
    color: var(--gray-mid);
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .dropdown li a:hover {
    background: var(--sapphire-light, #e8eeff);
    color: var(--sapphire);
  }

  .nav-right {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn-nav-ghost {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sapphire);
    background: transparent;
    border: 1.5px solid var(--sapphire);
    padding: 8px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-nav-ghost:hover { background: var(--sapphire-light); }

  .btn-nav-solid {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--white);
    background: var(--sapphire);
    border: none;
    padding: 8px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-nav-solid:hover { background: var(--sapphire-dark); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--black);
    border-radius: 2px;
    transition: all 0.2s;
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 68px; left: 0; right: 0;
    background: var(--white);
    border-bottom: 1px solid var(--gray-light);
    padding: 16px 24px 24px;
    z-index: 99;
  }
  .mobile-menu.is-open { display: block; }
  .mobile-menu ul { display: flex; flex-direction: column; gap: 4px; }
  .mobile-menu a {
    display: block;
    padding: 10px 14px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-dark);
    border-radius: 6px;
    transition: background 0.2s, color 0.2s;
  }
  .mobile-menu a:hover { background: var(--sapphire-light); color: var(--sapphire); }

  /* Mobile dropdown */
  .mobile-dropdown-toggle {
    display: block;
    width: 100%;
    text-align: left;
    padding: 10px 14px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-dark);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    font-family: inherit;
  }
  .mobile-dropdown-toggle:hover { background: var(--sapphire-light); color: var(--sapphire); }
  .mobile-dropdown-list {
    display: none;
    padding-left: 16px;
    list-style: none;
  }
  .mobile-dropdown-list.is-open { display: block; }
  .mobile-dropdown-list a {
    font-size: 0.84rem;
    padding: 8px 14px;
  }

  @media (max-width: 960px) {
    nav { padding: 0 24px; }
    .nav-links, .nav-right { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    menu.setAttribute('aria-hidden', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Mobile dropdowns
  document.querySelectorAll('.mobile-dropdown-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const list = btn.nextElementSibling as HTMLElement | null;
      list?.classList.toggle('is-open');
      const arrow = btn.querySelector('.dd-arrow');
      if (arrow) arrow.textContent = list?.classList.contains('is-open') ? '▴' : '▾';
    });
  });
</script>
