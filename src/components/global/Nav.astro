---
import { Languages } from '@lucide/astro';
import { categories } from '../../data/products';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);

const productLinks = categories.map(cat => ({
  label: t(`nav.cat.${cat.slug}`),
  href: lp(`/products#${cat.slug}`),
}));

const technologyLinks = [
  { label: t('nav.tech.process'), href: lp('/technology') },
  { label: t('nav.tech.keyhole'), href: lp('/keyhole-tig-welding') },
  { label: t('nav.tech.cladding'), href: lp('/weld-overlay-cladding') },
];

const industryLinks = [
  { label: t('nav.ind.aerospace'), href: lp('/industries/aerospace') },
  { label: t('nav.ind.defense'), href: lp('/industries/defense') },
  { label: t('nav.ind.food-dairy'), href: lp('/industries/food-dairy') },
  { label: t('nav.ind.heat-exchangers'), href: lp('/industries/heat-exchangers') },
  { label: t('nav.ind.nuclear'), href: lp('/industries/nuclear') },
  { label: t('nav.ind.oil-gas'), href: lp('/industries/oil-gas') },
  { label: t('nav.ind.petrochemical'), href: lp('/industries/petrochemical') },
  { label: t('nav.ind.pharma'), href: lp('/industries/pharma') },
  { label: t('nav.ind.pipelines'), href: lp('/industries/pipelines') },
  { label: t('nav.ind.power-generation'), href: lp('/industries/power-generation') },
  { label: t('nav.ind.shipbuilding'), href: lp('/industries/shipbuilding') },
];

const supportLinks = [
  { label: t('nav.sup.wire-speed'), href: lp('/support/wire-speed-calculator') },
  { label: t('nav.sup.software'), href: lp('/support/software-update') },
  { label: t('nav.sup.control-panel'), href: lp('/support/control-panel') },
  { label: t('nav.sup.warranty'), href: lp('/support/warranty') },
  { label: t('nav.sup.manuals'), href: lp('/support/manuals') },
  { label: t('nav.sup.service'), href: 'https://repair.tiptig.com', external: true },
];

const companyLinks = [
  { label: t('nav.com.about'), href: lp('/about') },
  { label: t('nav.com.contact'), href: lp('/contact') },
];

// Language switcher: paths for both languages
const currentPath = Astro.url.pathname;
const enPath = lang === 'de' ? (currentPath.replace(/^\/de/, '') || '/') : currentPath;
const dePath = lang === 'de' ? currentPath : `/de${currentPath === '/' ? '' : currentPath}`;
const switchPath = lang === 'de' ? enPath : dePath;

const navSections = [
  { label: t('nav.products'), href: lp('/products'), links: productLinks },
  { label: t('nav.technology'), href: lp('/technology'), links: technologyLinks },
  { label: t('nav.industries'), href: lp('/industries'), links: industryLinks },
  { label: t('nav.support'), href: lp('/support'), links: supportLinks },
  { label: t('nav.company'), href: lp('/about'), links: companyLinks },
];
---

<nav>
  <a href={lp('/')} class="logo">
    <img src="/images/Logo_fuer_Homepage_24r.svg" alt="TIP TIG" height="36" />
  </a>

  <ul class="nav-links">
    {navSections.map(section => (
      <li class="has-dropdown">
        <a href={section.href}>{section.label} <span class="dd-arrow">▾</span></a>
        <ul class="dropdown">
          {section.links.map(link => (
            <li><a href={link.href} {...((link as any).external ? { target: '_blank', rel: 'noopener' } : {})}>{link.label}</a></li>
          ))}
        </ul>
      </li>
    ))}
    <li class="lang-switch has-dropdown">
      <button class="lang-toggle" aria-label="Language"><Languages size={18} /></button>
      <ul class="dropdown lang-dropdown">
        <li><a href={enPath} class={lang === 'en' ? 'is-active' : ''}>English</a></li>
        <li><a href={dePath} class={lang === 'de' ? 'is-active' : ''}>Deutsch</a></li>
      </ul>
    </li>
  </ul>

  <!-- Mobile Toggle -->
  <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <ul>
    {navSections.map(section => (
      <li class="mobile-dropdown">
        <button class="mobile-dropdown-toggle">{section.label} <span class="dd-arrow">▾</span></button>
        <ul class="mobile-dropdown-list">
          {section.links.map(link => (
            <li><a href={link.href} {...((link as any).external ? { target: '_blank', rel: 'noopener' } : {})}>{link.label}</a></li>
          ))}
        </ul>
      </li>
    ))}
    <li class="mobile-lang">
      <div class="mobile-lang-links">
        <a href={enPath} class={lang === 'en' ? 'is-active' : ''}>English</a>
        <a href={dePath} class={lang === 'de' ? 'is-active' : ''}>Deutsch</a>
      </div>
    </li>
  </ul>
</div>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--gray-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 60px;
    height: 68px;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .logo img {
    height: 68px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
    align-items: center;
  }
  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gray-mid);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }
  .nav-links a:hover { color: var(--sapphire); }

  /* Language switcher — globe icon */
  .lang-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--gray-light);
    border-radius: 8px;
    background: transparent;
    color: var(--gray-mid);
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
  }
  .lang-toggle:hover {
    border-color: var(--sapphire);
    color: var(--sapphire);
    background: var(--sapphire-light);
  }
  .lang-switch .lang-dropdown {
    min-width: 140px;
    right: 0;
    left: auto;
    transform: none;
  }
  .lang-switch .lang-dropdown a.is-active {
    color: var(--sapphire);
    font-weight: 600;
    background: var(--sapphire-light, #e8eeff);
  }

  /* Dropdown */
  .has-dropdown { position: relative; }
  .dd-arrow { font-size: 0.7em; margin-left: 2px; }
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    padding: 8px 0;
    min-width: 200px;
    z-index: 101;
    list-style: none;
  }
  .has-dropdown:hover .dropdown { display: block; }
  .dropdown li a {
    display: block;
    padding: 8px 20px;
    font-size: 0.84rem;
    font-weight: 400;
    color: var(--gray-mid);
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .dropdown li a:hover {
    background: var(--sapphire-light, #e8eeff);
    color: var(--sapphire);
  }

  .nav-right {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn-nav-ghost {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sapphire);
    background: transparent;
    border: 1.5px solid var(--sapphire);
    padding: 8px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-nav-ghost:hover { background: var(--sapphire-light); }

  .btn-nav-solid {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--white);
    background: var(--sapphire);
    border: none;
    padding: 8px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-nav-solid:hover { background: var(--sapphire-dark); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--black);
    border-radius: 2px;
    transition: all 0.2s;
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 68px; left: 0; right: 0; bottom: 0;
    background: var(--white);
    border-bottom: 1px solid var(--gray-light);
    padding: 16px 24px 24px;
    z-index: 99;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .mobile-menu.is-open { display: block; }
  .mobile-menu ul { display: flex; flex-direction: column; gap: 4px; }
  .mobile-menu a {
    display: block;
    padding: 10px 14px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-dark);
    border-radius: 6px;
    transition: background 0.2s, color 0.2s;
  }
  .mobile-menu a:hover { background: var(--sapphire-light); color: var(--sapphire); }

  /* Mobile dropdown */
  .mobile-dropdown-toggle {
    display: block;
    width: 100%;
    text-align: left;
    padding: 10px 14px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-dark);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    font-family: inherit;
  }
  .mobile-dropdown-toggle:hover { background: var(--sapphire-light); color: var(--sapphire); }
  .mobile-dropdown-list {
    display: none;
    padding-left: 16px;
    list-style: none;
  }
  .mobile-dropdown-list.is-open { display: block; }
  .mobile-dropdown-list a {
    font-size: 0.84rem;
    padding: 8px 14px;
  }

  /* Mobile language switch */
  .mobile-lang {
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--gray-light);
  }
  .mobile-lang-links {
    display: flex;
    gap: 8px;
  }
  .mobile-lang-links a {
    flex: 1;
    text-align: center;
    padding: 10px 14px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--gray-mid);
    border: 1px solid var(--gray-light);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .mobile-lang-links a.is-active {
    color: var(--sapphire);
    font-weight: 700;
    border-color: var(--sapphire);
    background: var(--sapphire-light);
  }
  .mobile-lang-links a:not(.is-active):hover {
    border-color: var(--sapphire);
    color: var(--sapphire);
  }

  @media (max-width: 960px) {
    nav { padding: 0 24px; }
    .nav-links, .nav-right { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    menu.setAttribute('aria-hidden', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Mobile dropdowns
  document.querySelectorAll('.mobile-dropdown-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const list = btn.nextElementSibling as HTMLElement | null;
      list?.classList.toggle('is-open');
      const arrow = btn.querySelector('.dd-arrow');
      if (arrow) arrow.textContent = list?.classList.contains('is-open') ? '▴' : '▾';
    });
  });
</script>
