---
import { Target, Lightbulb, Handshake, Leaf } from '@lucide/astro';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
---

<section class="ab-values">
  <div class="inner">
    <div class="ab-values-header reveal">
      <div class="section-eyebrow">{t('about.values.eyebrow')}</div>
      <h2 class="section-title"><Fragment set:html={t('about.values.title')} /></h2>
      <p class="section-lead">
        {t('about.values.lead')}
      </p>
    </div>

    <div class="ab-values-grid">
      <div class="ab-value-card reveal">
        <div class="ab-value-icon"><Target size={22} /></div>
        <h3>{t('about.values.precision')}</h3>
        <p>
          {t('about.values.precision.desc')}
        </p>
      </div>

      <div class="ab-value-card reveal reveal-delay-1">
        <div class="ab-value-icon"><Lightbulb size={22} /></div>
        <h3>{t('about.values.innovation')}</h3>
        <p>
          {t('about.values.innovation.desc')}
        </p>
      </div>

      <div class="ab-value-card reveal reveal-delay-2">
        <div class="ab-value-icon"><Handshake size={22} /></div>
        <h3>{t('about.values.partnership')}</h3>
        <p>
          {t('about.values.partnership.desc')}
        </p>
      </div>

      <div class="ab-value-card reveal reveal-delay-3">
        <div class="ab-value-icon"><Leaf size={22} /></div>
        <h3>{t('about.values.sustainable')}</h3>
        <p>
          {t('about.values.sustainable.desc')}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .ab-values {
    padding: 110px 60px;
    background: var(--white);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ab-values-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before,
  .section-eyebrow::after {
    content: '';
    display: block;
    width: 24px; height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto;
  }

  .ab-values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .ab-value-card {
    background: var(--bg);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 36px 28px;
    transition: all 0.3s;
  }
  .ab-value-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 32px rgba(27, 58, 140, 0.08);
    transform: translateY(-3px);
  }

  .ab-value-icon {
    width: 48px; height: 48px;
    background: var(--sapphire-light);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
    margin-bottom: 20px;
    transition: all 0.25s;
  }
  .ab-value-card:hover .ab-value-icon {
    background: var(--sapphire);
    color: var(--white);
  }

  h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--black);
    margin-bottom: 10px;
  }

  .ab-value-card p {
    font-size: 0.88rem;
    color: var(--gray-mid);
    line-height: 1.7;
    font-weight: 300;
  }

  @media (max-width: 960px) {
    .ab-values { padding: 72px 24px; }
    .ab-values-grid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 560px) {
    .ab-values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
