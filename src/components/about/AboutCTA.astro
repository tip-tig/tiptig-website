<section class="ab-cta">
  <div class="inner reveal">
    <div class="ab-cta-eyebrow">Ready to Learn More?</div>
    <h2>Discover What TIP TIG<br>Can Do for You.</h2>
    <p>Explore our technology in detail or connect with a Certified Partner in your region.</p>
    <div class="ab-cta-buttons">
      <a href="/technology" class="btn-primary">Explore Our Technology</a>
      <a href="/contact" class="btn-ghost">Find a Partner</a>
    </div>
  </div>
</section>

<style>
  .ab-cta {
    padding: 110px 60px;
    background: var(--white);
    text-align: center;
  }

  .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .ab-cta-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 20px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .ab-cta-eyebrow::before,
  .ab-cta-eyebrow::after {
    content: '';
    display: block;
    width: 24px; height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  h2 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
  }

  p {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--gray-mid);
    line-height: 1.75;
    margin-bottom: 36px;
  }

  .ab-cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--white);
    background: var(--sapphire);
    border: none;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s;
  }
  .btn-primary:hover {
    background: var(--sapphire-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(27, 58, 140, 0.2);
  }

  .btn-ghost {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--black);
    background: transparent;
    border: 1px solid var(--gray-light);
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s;
  }
  .btn-ghost:hover {
    border-color: var(--sapphire);
    color: var(--sapphire);
  }

  @media (max-width: 960px) {
    .ab-cta { padding: 72px 24px; }
    .ab-cta-buttons { flex-direction: column; align-items: center; }
  }
</style>
