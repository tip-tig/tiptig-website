---
import { Plane, Atom, Fuel, Zap, FlaskConical, Heater, UtensilsCrossed, Layers, Cable, Shield, Ship, Pill } from '@lucide/astro';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
---

<section class="section section-alt">
  <div class="inner">
    <div class="section-eyebrow reveal">{t('industries.eyebrow')}</div>
    <h2 class="section-title reveal"><Fragment set:html={t('industries.title')} /></h2>
    <p class="section-lead reveal">{t('industries.lead')}</p>

    <div class="industries-grid">
      <a href={lp('/industries/aerospace')} class="industry-card reveal reveal-delay-1">
        <span class="industry-icon"><Plane size={24} /></span>
        <div class="industry-name">{t('industries.card.aerospace')}</div>
        <p class="industry-desc">{t('industries.card.aerospace.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/nuclear')} class="industry-card reveal reveal-delay-2">
        <span class="industry-icon"><Atom size={24} /></span>
        <div class="industry-name">{t('industries.card.nuclear')}</div>
        <p class="industry-desc">{t('industries.card.nuclear.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/oil-gas')} class="industry-card reveal reveal-delay-1">
        <span class="industry-icon"><Fuel size={24} /></span>
        <div class="industry-name">{t('industries.card.oil-gas')}</div>
        <p class="industry-desc">{t('industries.card.oil-gas.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/power-generation')} class="industry-card reveal reveal-delay-2">
        <span class="industry-icon"><Zap size={24} /></span>
        <div class="industry-name">{t('industries.card.power')}</div>
        <p class="industry-desc">{t('industries.card.power.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/petrochemical')} class="industry-card reveal reveal-delay-1">
        <span class="industry-icon"><FlaskConical size={24} /></span>
        <div class="industry-name">{t('industries.card.petrochem')}</div>
        <p class="industry-desc">{t('industries.card.petrochem.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/heat-exchangers')} class="industry-card reveal reveal-delay-2">
        <span class="industry-icon"><Heater size={24} /></span>
        <div class="industry-name">{t('industries.card.heat')}</div>
        <p class="industry-desc">{t('industries.card.heat.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/food-dairy')} class="industry-card reveal reveal-delay-1">
        <span class="industry-icon"><UtensilsCrossed size={24} /></span>
        <div class="industry-name">{t('industries.card.food')}</div>
        <p class="industry-desc">{t('industries.card.food.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/weld-overlay-cladding')} class="industry-card reveal reveal-delay-2">
        <span class="industry-icon"><Layers size={24} /></span>
        <div class="industry-name">{t('industries.card.cladding')}</div>
        <p class="industry-desc">{t('industries.card.cladding.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/pipelines')} class="industry-card reveal reveal-delay-1">
        <span class="industry-icon"><Cable size={24} /></span>
        <div class="industry-name">{t('industries.card.pipelines')}</div>
        <p class="industry-desc">{t('industries.card.pipelines.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/defense')} class="industry-card reveal reveal-delay-2">
        <span class="industry-icon"><Shield size={24} /></span>
        <div class="industry-name">{t('industries.card.defense')}</div>
        <p class="industry-desc">{t('industries.card.defense.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/shipbuilding')} class="industry-card reveal reveal-delay-1">
        <span class="industry-icon"><Ship size={24} /></span>
        <div class="industry-name">{t('industries.card.shipbuilding')}</div>
        <p class="industry-desc">{t('industries.card.shipbuilding.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>

      <a href={lp('/industries/pharma')} class="industry-card reveal reveal-delay-2">
        <span class="industry-icon"><Pill size={24} /></span>
        <div class="industry-name">{t('industries.card.pharma')}</div>
        <p class="industry-desc">{t('industries.card.pharma.desc')}</p>
        <span class="industry-arrow">{t('industries.cta')}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 110px 60px;
  }
  .section-alt { background: var(--bg); }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px; height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .industry-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 14px;
    padding: 28px 24px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
    display: block;
  }
  .industry-card:hover {
    border-color: var(--sapphire);
    box-shadow: 0 8px 32px rgba(27,58,140,0.1);
    transform: translateY(-3px);
  }

  .industry-icon {
    display: block;
    margin-bottom: 14px;
    color: var(--sapphire);
    line-height: 0;
  }

  .industry-name {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--black);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .industry-desc {
    font-size: 0.82rem;
    color: var(--gray-mid);
    line-height: 1.5;
    font-weight: 300;
  }

  .industry-arrow {
    display: inline-block;
    margin-top: 16px;
    font-size: 0.8rem;
    color: var(--sapphire);
    font-weight: 500;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .industry-card:hover .industry-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  @media (max-width: 960px) {
    .section { padding: 72px 24px; }
    .industries-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  }
  @media (max-width: 480px) {
    .industries-grid { grid-template-columns: 1fr; }
  }
</style>
