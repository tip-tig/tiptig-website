---
import { Play } from '@lucide/astro';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
---

<section class="hero">
  <div class="hero-bg-shape"></div>

  <!-- Left: Text -->
  <div class="hero-content">
    <div class="hero-tag">
      <span class="hero-tag-dot"></span>
      {t('hero.tag1')}
      <span class="hero-tag-dot"></span>
      {t('hero.tag2')}
    </div>

    <h1>
      <Fragment set:html={t('hero.title.line1')} /><br>
      <span class="blue"><Fragment set:html={t('hero.title.line2')} /></span><br>
      <Fragment set:html={t('hero.title.line3')} />
    </h1>

    <p class="hero-desc">
      {t('hero.desc')}
    </p>

    <div class="hero-actions">
      <a href={lp('/products')} class="btn-primary">{t('hero.cta.discover')}</a>
      <a href={lp('/technology#video')} class="btn-ghost">
        <span class="play-icon"><Play size={10} color="white" fill="white" /></span>
        {t('hero.cta.watch')}
      </a>
    </div>

  </div>

  <!-- Right: Product Image -->
  <div class="hero-visual">
    <div class="hero-image-wrapper">
      <img src="/images/products/tiptig-allinone-torch.webp" alt={t('hero.alt')} width="1200" height="1200" />
    </div>
  </div>
</section>

<div class="hero-highlights">
  <div class="highlight-item">
    <span class="highlight-value">300%</span>
    <span class="highlight-label">{t('highlight.faster')}</span>
  </div>
  <div class="highlight-divider"></div>
  <div class="highlight-item">
    <span class="highlight-value">400%</span>
    <span class="highlight-label">{t('highlight.deposition')}</span>
  </div>
  <div class="highlight-divider"></div>
  <div class="highlight-item">
    <span class="highlight-value">72%</span>
    <span class="highlight-label">{t('highlight.savings')}</span>
  </div>
  <div class="highlight-divider"></div>
  <div class="highlight-item">
    <span class="highlight-value">80%</span>
    <span class="highlight-label">{t('highlight.dilution')}</span>
  </div>
</div>

<style>
  .hero {
    min-height: 100vh;
    padding: 140px 60px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    background: var(--white);
    position: relative;
    overflow: hidden;
  }

  .hero-bg-shape {
    position: absolute;
    top: -200px; right: -300px;
    width: 800px; height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--sapphire-light) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Left content */
  .hero-content {
    position: relative;
    z-index: 2;
    animation: heroIn 0.8s cubic-bezier(0.16,1,0.3,1) both;
  }

  @keyframes heroIn {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--sapphire-light);
    color: var(--sapphire);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 28px;
    border: 1px solid var(--sapphire-mid);
  }

  .hero-tag-dot {
    width: 6px; height: 6px;
    background: var(--sapphire);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.8); }
  }

  h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 24px;
  }
  h1 .blue { color: var(--sapphire); }

  .hero-desc {
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 500px;
    margin-bottom: 24px;
  }

  /* Highlights bar below hero */
  .hero-highlights {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 48px;
    padding: 40px 60px;
    background: var(--sapphire);
  }

  .highlight-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .highlight-value {
    font-family: 'Manrope', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .highlight-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .highlight-divider {
    width: 1px;
    height: 48px;
    background: rgba(255,255,255,0.2);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
    background: var(--sapphire);
    border: none;
    padding: 14px 28px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-block;
    letter-spacing: 0.01em;
  }
  .btn-primary:hover {
    background: var(--sapphire-dark);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(27,58,140,0.25);
  }

  .btn-ghost {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--black);
    background: transparent;
    border: 1.5px solid var(--gray-light);
    padding: 13px 24px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-ghost:hover { border-color: var(--sapphire); color: var(--sapphire); }

  .play-icon {
    width: 20px; height: 20px;
    background: var(--sapphire);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.55rem;
    padding-left: 2px;
    flex-shrink: 0;
  }


  /* Right: Image area */
  .hero-visual {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: heroVisualIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  @keyframes heroVisualIn {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hero-image-wrapper {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image-wrapper img {
    width: 100%;
    max-width: 560px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 60px rgba(27,58,140,0.15));
  }

  /* Platzhalter */
  .hero-image-placeholder {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 1;
    background: var(--bg);
    border: 2px dashed var(--gray-light);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .placeholder-label {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--gray-mid);
  }

  .placeholder-sub {
    font-size: 0.78rem;
    color: var(--sapphire-mid);
    font-weight: 400;
  }

  .hero-footnote {
    font-size: 0.7rem;
    color: var(--gray-mid);
    margin-top: 16px;
    font-weight: 300;
    opacity: 0.7;
    text-align: center;
  }

  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 120px 24px 60px;
      gap: 40px;
    }
    .hero-bg-shape { display: none; }
    .hero-highlights {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding: 32px 24px;
    }
    .highlight-value {
      font-size: 1.8rem;
    }
    .highlight-label {
      font-size: 0.7rem;
    }
    .highlight-divider {
      display: none;
    }
  }
</style>
