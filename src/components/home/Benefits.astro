---
import { Zap, Sparkles, Thermometer, Shield, GraduationCap, Wind } from '@lucide/astro';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
---

<section class="split-section">
  <!-- Left: Benefits list -->
  <div class="reveal">
    <div class="section-eyebrow">{t('benefits.eyebrow')}</div>
    <h2 class="section-title"><Fragment set:html={t('benefits.title')} /><br><Fragment set:html={t('benefits.title2')} /></h2>
    <p class="section-lead">
      {t('benefits.desc')}
    </p>

    <div class="benefits-list">
      <div class="benefit-item">
        <div class="benefit-icon"><Zap size={16} /></div>
        <div class="benefit-text">
          <strong>{t('benefits.1.title')}</strong>
          <span>{t('benefits.1.desc')}</span>
        </div>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon"><Sparkles size={16} /></div>
        <div class="benefit-text">
          <strong>{t('benefits.2.title')}</strong>
          <span>{t('benefits.2.desc')}</span>
        </div>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon"><Thermometer size={16} /></div>
        <div class="benefit-text">
          <strong>{t('benefits.3.title')}</strong>
          <span>{t('benefits.3.desc')}</span>
        </div>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon"><Shield size={16} /></div>
        <div class="benefit-text">
          <strong>{t('benefits.4.title')}</strong>
          <span>{t('benefits.4.desc')}</span>
        </div>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon"><GraduationCap size={16} /></div>
        <div class="benefit-text">
          <strong>{t('benefits.5.title')}</strong>
          <span>{t('benefits.5.desc')}</span>
        </div>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon"><Wind size={16} /></div>
        <div class="benefit-text">
          <strong>{t('benefits.6.title')}</strong>
          <span>{t('benefits.6.desc')}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Right: ROI panel -->
  <div class="roi-panel reveal reveal-delay-2">
    <div class="roi-eyebrow">{t('roi.eyebrow')}</div>
    <div class="roi-big">9.3</div>
    <div class="roi-big-label">{t('roi.weeks')}</div>

    <div class="roi-grid">
      <div>
        <div class="roi-stat-val">{t('roi.saved6')}</div>
        <div class="roi-stat-label"><Fragment set:html={t('roi.pipe6')} /></div>
      </div>
      <div>
        <div class="roi-stat-val">{t('roi.saved12')}</div>
        <div class="roi-stat-label"><Fragment set:html={t('roi.pipe12')} /></div>
      </div>
      <div>
        <div class="roi-stat-val">{t('roi.breakeven6')}</div>
        <div class="roi-stat-label"><Fragment set:html={t('roi.schedule6')} /></div>
      </div>
      <div>
        <div class="roi-stat-val">{t('roi.breakeven12')}</div>
        <div class="roi-stat-label"><Fragment set:html={t('roi.schedule12')} /></div>
      </div>
    </div>

    <div class="roi-divider"></div>
    <a href={lp('/roi-calculator')} class="btn-white">{t('roi.cta')}</a>
  </div>
</section>

<style>
  .split-section {
    padding: 110px 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px; height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 20px;
    border-radius: 10px;
    transition: all 0.2s;
    cursor: default;
  }
  .benefit-item:hover { background: var(--sapphire-light); }

  .benefit-icon {
    width: 32px; height: 32px;
    background: var(--sapphire-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
    transition: background 0.2s;
    color: var(--sapphire);
  }
  .benefit-item:hover .benefit-icon {
    background: var(--sapphire);
    color: var(--white);
  }

  .benefit-text strong {
    display: block;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--black);
    margin-bottom: 3px;
  }
  .benefit-text span {
    font-size: 0.85rem;
    color: var(--gray-mid);
    font-weight: 300;
    line-height: 1.5;
  }

  /* ROI Panel */
  .roi-panel {
    background: var(--sapphire);
    border-radius: 24px;
    padding: 52px 48px;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .roi-panel::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 350px; height: 350px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
  }

  .roi-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 12px;
  }

  .roi-big {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 5rem;
    line-height: 1;
    margin-bottom: 4px;
  }

  .roi-big-label {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 32px;
    font-weight: 300;
  }

  .roi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 36px;
  }

  .roi-stat-val {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.8rem;
    color: white;
    line-height: 1;
    margin-bottom: 4px;
  }

  .roi-stat-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .roi-divider {
    height: 1px;
    background: rgba(255,255,255,0.12);
    margin: 0 0 28px;
  }

  .btn-white {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sapphire);
    background: var(--white);
    border: none;
    padding: 13px 26px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: block;
    width: 100%;
    text-align: center;
  }
  .btn-white:hover { background: var(--gray-light); }

  @media (max-width: 960px) {
    .split-section {
      grid-template-columns: 1fr;
      padding: 72px 24px;
      gap: 48px;
    }
  }
</style>
