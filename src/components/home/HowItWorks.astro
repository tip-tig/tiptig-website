---
import { Zap, Thermometer, Sparkles } from '@lucide/astro';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section class="section section-alt">
  <div class="inner">
    <div class="section-eyebrow reveal">{t('how.eyebrow')}</div>
    <h2 class="section-title reveal">{t('how.title')}</h2>
    <p class="section-lead reveal">
      {t('how.desc')}
    </p>

    <div class="steps-grid">
      <div class="step-card reveal reveal-delay-1">
        <span class="step-num">Step 01</span>
        <span class="step-icon"><Zap size={28} color="var(--sapphire)" /></span>
        <div class="step-title">{t('how.step1.title')}</div>
        <p class="step-desc">{t('how.step1.desc')}</p>
      </div>

      <div class="step-card reveal reveal-delay-2">
        <span class="step-num">Step 02</span>
        <span class="step-icon"><Thermometer size={28} color="var(--sapphire)" /></span>
        <div class="step-title">{t('how.step2.title')}</div>
        <p class="step-desc">{t('how.step2.desc')}</p>
      </div>

      <div class="step-card reveal reveal-delay-3">
        <span class="step-num">Step 03</span>
        <span class="step-icon"><Sparkles size={28} color="var(--sapphire)" /></span>
        <div class="step-title">{t('how.step3.title')}</div>
        <p class="step-desc">{t('how.step3.desc')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 110px 60px;
  }
  .section-alt {
    background: var(--bg);
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px; height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .step-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 36px 32px;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .step-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 16px 48px rgba(27,58,140,0.1);
    transform: translateY(-4px);
  }

  .step-num {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--sapphire);
    background: var(--sapphire-light);
    padding: 4px 10px;
    border-radius: 100px;
    display: inline-block;
    margin-bottom: 20px;
  }

  .step-icon {
    display: block;
    margin-bottom: 16px;
    line-height: 0;
  }

  .step-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--black);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--gray-mid);
    line-height: 1.7;
    font-weight: 300;
  }

  @media (max-width: 960px) {
    .section { padding: 72px 24px; }
    .steps-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  }
  @media (max-width: 600px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
