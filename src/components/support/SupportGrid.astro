---
import { Calculator, Download, Wrench, Shield, BookOpen, Mail, Monitor } from '@lucide/astro';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
---

<section class="sp-grid-section">
  <div class="inner">
    <div class="sp-grid">

      <a href={lp('/support/wire-speed-calculator')} class="sp-card reveal">
        <div class="sp-card-icon"><Calculator size={24} /></div>
        <h3>{t('support.card.wirespeed')}</h3>
        <p>{t('support.card.wirespeed.desc')}</p>
        <span class="sp-card-link">{t('support.card.wirespeed.link')}</span>
      </a>

      <a href={lp('/support/software-update')} class="sp-card reveal reveal-delay-1">
        <div class="sp-card-icon"><Download size={24} /></div>
        <h3>{t('support.card.software')}</h3>
        <p>{t('support.card.software.desc')}</p>
        <span class="sp-card-link">{t('support.card.software.link')}</span>
      </a>

      <a href="https://repair.tiptig.com" target="_blank" rel="noopener" class="sp-card reveal reveal-delay-2">
        <div class="sp-card-icon"><Wrench size={24} /></div>
        <h3>{t('support.card.service')}</h3>
        <p>{t('support.card.service.desc')}</p>
        <span class="sp-card-link">{t('support.card.service.link')}</span>
      </a>

      <a href={lp('/support/control-panel')} class="sp-card reveal">
        <div class="sp-card-icon"><Monitor size={24} /></div>
        <h3>{t('support.card.controlpanel')}</h3>
        <p>{t('support.card.controlpanel.desc')}</p>
        <span class="sp-card-link">{t('support.card.controlpanel.link')}</span>
      </a>

      <a href={lp('/support/warranty')} class="sp-card reveal">
        <div class="sp-card-icon"><Shield size={24} /></div>
        <h3>{t('support.card.warranty')}</h3>
        <p>{t('support.card.warranty.desc')}</p>
        <span class="sp-card-link">{t('support.card.warranty.link')}</span>
      </a>

      <a href={lp('/support/manuals')} class="sp-card reveal reveal-delay-1">
        <div class="sp-card-icon"><BookOpen size={24} /></div>
        <h3>{t('support.card.manuals')}</h3>
        <p>{t('support.card.manuals.desc')}</p>
        <span class="sp-card-link">{t('support.card.manuals.link')}</span>
      </a>

      <a href={lp('/contact')} class="sp-card reveal reveal-delay-2">
        <div class="sp-card-icon"><Mail size={24} /></div>
        <h3>{t('support.card.contact')}</h3>
        <p>{t('support.card.contact.desc')}</p>
        <span class="sp-card-link">{t('support.card.contact.link')}</span>
      </a>

    </div>
  </div>
</section>

<style>
  .sp-grid-section {
    padding: 80px 60px 110px;
    background: var(--bg);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .sp-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 36px 32px;
    text-decoration: none;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
  }
  .sp-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 32px rgba(27, 58, 140, 0.08);
    transform: translateY(-3px);
  }

  .sp-card-icon {
    width: 52px; height: 52px;
    background: var(--sapphire-light);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
    margin-bottom: 24px;
    transition: all 0.25s;
  }
  .sp-card:hover .sp-card-icon {
    background: var(--sapphire);
    color: var(--white);
  }

  h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--black);
    margin-bottom: 10px;
  }

  .sp-card p {
    font-size: 0.88rem;
    color: var(--gray-mid);
    line-height: 1.7;
    font-weight: 300;
    flex: 1;
    margin-bottom: 20px;
  }

  .sp-card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sapphire);
    transition: gap 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .sp-card:hover .sp-card-link {
    text-decoration: underline;
  }

  @media (max-width: 960px) {
    .sp-grid-section { padding: 48px 24px 72px; }
    .sp-grid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 560px) {
    .sp-grid { grid-template-columns: 1fr; }
  }
</style>
