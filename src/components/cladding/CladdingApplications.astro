---
import { Waves, Circle, Wind, Cog, Pipette, Hammer } from '@lucide/astro';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const applications = [
  { icon: 'Waves', titleKey: 'cl.app.a1' },
  { icon: 'Circle', titleKey: 'cl.app.a2' },
  { icon: 'Wind', titleKey: 'cl.app.a3' },
  { icon: 'Cog', titleKey: 'cl.app.a4' },
  { icon: 'Pipette', titleKey: 'cl.app.a5' },
  { icon: 'Hammer', titleKey: 'cl.app.a6' },
];

const appIconMap: Record<string, any> = { Waves, Circle, Wind, Cog, Pipette, Hammer };

const industryKeys = [
  'cl.app.ind1', 'cl.app.ind2', 'cl.app.ind3', 'cl.app.ind4', 'cl.app.ind5', 'cl.app.ind6',
  'cl.app.ind7', 'cl.app.ind8', 'cl.app.ind9', 'cl.app.ind10', 'cl.app.ind11', 'cl.app.ind12',
];
---

<section class="cl-applications">
  <div class="inner">
    <div class="cl-app-grid">
      <div class="cl-app-left">
        <div class="section-eyebrow reveal">{t('cl.app.eyebrow')}</div>
        <h2 class="section-title reveal">{t('cl.app.title')}<br>{t('cl.app.title2')}</h2>
        <div class="app-list reveal">
          {applications.map((app) => {
            const Icon = appIconMap[app.icon];
            return (
              <div class="app-item">
                <div class="app-icon"><Icon size={20} /></div>
                <span>{t(app.titleKey)}</span>
              </div>
            );
          })}
        </div>
      </div>

      <div class="cl-app-right">
        <div class="section-eyebrow reveal">{t('cl.app.ind.eyebrow')}</div>
        <h2 class="section-title reveal">{t('cl.app.ind.title')}<br>{t('cl.app.ind.title2')}</h2>
        <div class="ind-tags reveal">
          {industryKeys.map((key) => (
            <span class="ind-tag">{t(key)}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cl-applications {
    padding: 110px 60px;
    background: var(--bg);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .cl-app-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 24px;
  }

  /* Application list */
  .app-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .app-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 10px;
    transition: all 0.2s;
  }

  .app-item:hover {
    border-color: var(--sapphire-mid);
    transform: translateX(4px);
  }

  .app-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    background: var(--sapphire-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
  }

  .app-item span {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--black);
  }

  /* Industry tags */
  .ind-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ind-tag {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--sapphire);
    background: var(--white);
    border: 1px solid var(--sapphire-mid);
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .ind-tag:hover {
    background: var(--sapphire);
    color: white;
    border-color: var(--sapphire);
  }

  @media (max-width: 960px) {
    .cl-applications { padding: 72px 24px; }
    .cl-app-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }
</style>
