---
import { Sparkles, Thermometer, Gauge, TrendingUp, ShieldCheck, Wind, Settings, Timer } from '@lucide/astro';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const benefits = [
  { icon: 'Sparkles', titleKey: 'cl.ben.b1.title', descKey: 'cl.ben.b1.desc' },
  { icon: 'Thermometer', titleKey: 'cl.ben.b2.title', descKey: 'cl.ben.b2.desc' },
  { icon: 'Gauge', titleKey: 'cl.ben.b3.title', descKey: 'cl.ben.b3.desc' },
  { icon: 'TrendingUp', titleKey: 'cl.ben.b4.title', subImpKey: 'cl.ben.b4.sub.imp', subMetKey: 'cl.ben.b4.sub.met', descKey: 'cl.ben.b4.desc' },
  { icon: 'ShieldCheck', titleKey: 'cl.ben.b5.title', descKey: 'cl.ben.b5.desc' },
  { icon: 'Wind', titleKey: 'cl.ben.b6.title', descKey: 'cl.ben.b6.desc' },
  { icon: 'Settings', titleKey: 'cl.ben.b7.title', descKey: 'cl.ben.b7.desc' },
  { icon: 'Timer', titleKey: 'cl.ben.b8.title', descKey: 'cl.ben.b8.desc' },
];

const iconMap: Record<string, any> = { Sparkles, Thermometer, Gauge, TrendingUp, ShieldCheck, Wind, Settings, Timer };
---

<section class="cl-benefits">
  <div class="inner">
    <div class="section-eyebrow reveal">{t('cl.ben.eyebrow')}</div>
    <h2 class="section-title reveal">{t('cl.ben.title')}</h2>
    <p class="section-lead reveal">
      {t('cl.ben.desc')}
    </p>

    <div class="benefits-grid">
      {benefits.map((b, i) => {
        const Icon = iconMap[b.icon];
        return (
          <div class={`benefit-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="benefit-icon"><Icon size={22} /></div>
            <h3>{t(b.titleKey)}{b.subImpKey && <> <span class="u-imp">{t(b.subImpKey)}</span><span class="u-met">{t(b.subMetKey!)}</span></>}</h3>
            <p>{t(b.descKey)}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .cl-benefits {
    padding: 110px 60px;
    background: var(--white);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .benefit-card {
    background: var(--bg);
    border: 1px solid var(--gray-light);
    border-radius: 14px;
    padding: 28px 24px;
    transition: all 0.3s ease;
  }

  .benefit-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 24px rgba(27, 58, 140, 0.08);
    transform: translateY(-3px);
  }

  .benefit-icon {
    width: 44px;
    height: 44px;
    background: var(--sapphire-light);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
    margin-bottom: 16px;
  }

  .benefit-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--black);
    margin-bottom: 6px;
  }

  .benefit-card p {
    font-size: 0.82rem;
    color: var(--gray-mid);
    line-height: 1.6;
    font-weight: 300;
  }

  @media (max-width: 960px) {
    .cl-benefits { padding: 72px 24px; }
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }
</style>
