---
---

<section class="ph-hero">
  <div class="ph-hero-bg"></div>
  <div class="inner">
    <div class="ph-eyebrow">Welding Equipment</div>
    <h1>Engineered for<br><span class="blue">Precision</span></h1>
    <p class="ph-desc">
      From compact wire feeders to automated cladding cells — every TIP TIG
      product is designed and manufactured in Austria to deliver the highest
      weld quality in the industry.
    </p>
  </div>
</section>

<style>
  .ph-hero {
    padding: 140px 60px 70px;
    background: var(--white);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .ph-hero-bg {
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 900px; height: 900px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--sapphire-light) 0%, transparent 70%);
    pointer-events: none;
  }
  .inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .ph-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 16px;
  }
  h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
  }
  .blue { color: var(--sapphire); }
  .ph-desc {
    font-size: 1rem;
    font-weight: 300;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto;
  }

  @media (max-width: 960px) {
    .ph-hero { padding: 120px 24px 48px; }
  }
</style>
