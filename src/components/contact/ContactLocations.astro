---

<section class="cl-locations">
  <div class="inner">

    {/* ── Tier 1: Certified Partners ──────────── */}
    <div class="section-eyebrow reveal"><span>Certified Partners</span></div>
    <h2 class="section-title reveal">Our Main Partners</h2>

    <div class="main-grid">
      {mainDealers.map((d, i) => (
        <div id={`dealer-${d.company.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '')}`} class={`main-card reveal ${i > 0 ? `reveal-delay-${Math.min(i % 3, 2)}` : ''}`}>
          <div class="main-badge"><Award size={13} /> Certified Partner</div>
          <h3>{d.company}</h3>
          <p class="main-region">{d.region}</p>
          <p class="main-city">{d.city}</p>
          <div class="main-links">
            {d.phone && <a href={`tel:${d.phone.replace(/\s/g, '')}`}>{d.phone}</a>}
            {d.email && <a href={`mailto:${d.email}`}>{d.email}</a>}
            {d.web && <a href={d.web.startsWith('http') ? d.web : `https://${d.web}`} target="_blank" rel="noopener">{d.web.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a>}
          </div>
        </div>
      ))}
    </div>

    {/* ── Tier 2: Regional Distributors ───────── */}
    <div class="sub-header">
      <div class="section-eyebrow reveal"><span>Regional Distributors</span></div>
      <h2 class="section-title section-title--sm reveal">Local Support Network</h2>
    </div>

    {subRegions.map((region) => (
      <div class="region-group">
        <div class="region-label reveal">
          <Globe size={16} />
          <span>{region.name}</span>
          <span class="region-count">{region.dealers.length}</span>
        </div>
        <div class="sub-grid">
          {region.dealers.map((d, i) => (
            <div id={`dealer-${d.company.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '')}`} class={`sub-card reveal ${i > 0 ? `reveal-delay-${Math.min(i % 3, 2)}` : ''}`}>
              <div class="sub-country">
                <MapPin size={12} />
                <span>{d.country}</span>
              </div>
              <h4>{d.company}</h4>
              <p class="sub-city">{d.city}</p>
              <div class="sub-links">
                {d.phone && <a href={`tel:${d.phone.replace(/\s/g, '')}`}>{d.phone}</a>}
                {d.email && <a href={`mailto:${d.email}`}>{d.email}</a>}
                {d.web && <a href={d.web.startsWith('http') ? d.web : `https://${d.web}`} target="_blank" rel="noopener">{d.web.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a>}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .cl-locations {
    padding: 110px 60px;
    background: var(--bg);
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Section headings ───────────────────────── */
  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }
  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 48px;
  }
  .section-title--sm {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 32px;
  }

  /* ── Tier 1: Main Dealers ───────────────────── */
  .main-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 72px;
  }

  .main-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 32px 28px;
    transition: all 0.3s ease;
  }
  .main-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 24px rgba(27, 58, 140, 0.08);
    transform: translateY(-2px);
  }

  .main-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sapphire);
    background: var(--sapphire-light);
    padding: 5px 12px;
    border-radius: 8px;
    margin-bottom: 16px;
  }
  .main-badge :global(svg) { color: var(--sapphire); }

  .main-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--black);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .main-region {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--sapphire);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }
  .main-city {
    font-size: 0.85rem;
    color: var(--gray-mid);
    font-weight: 300;
    margin-bottom: 16px;
  }

  .main-links {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .main-links a {
    font-size: 0.82rem;
    color: var(--gray-mid);
    font-weight: 400;
    transition: color 0.2s;
  }
  .main-links a:hover {
    color: var(--sapphire);
  }

  /* ── Sub-header spacing ─────────────────────── */
  .sub-header {
    margin-bottom: 0;
  }

  /* ── Tier 2: Region groups ──────────────────── */
  .region-group {
    margin-bottom: 36px;
  }
  .region-group:last-child {
    margin-bottom: 0;
  }

  .region-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--black);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--gray-light);
  }
  .region-label :global(svg) {
    color: var(--sapphire);
    flex-shrink: 0;
  }
  .region-count {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--sapphire);
    background: var(--sapphire-light);
    padding: 2px 8px;
    border-radius: 10px;
    margin-left: auto;
  }

  .sub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .sub-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 10px;
    padding: 20px 18px;
    transition: all 0.3s ease;
  }
  .sub-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 4px 12px rgba(27, 58, 140, 0.05);
  }

  .sub-country {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sapphire);
    margin-bottom: 6px;
  }
  .sub-country :global(svg) { flex-shrink: 0; }

  .sub-card h4 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--black);
    margin-bottom: 3px;
    line-height: 1.3;
  }
  .sub-city {
    font-size: 0.78rem;
    color: var(--gray-mid);
    font-weight: 300;
    margin-bottom: 10px;
  }

  .sub-links {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sub-links a {
    font-size: 0.74rem;
    color: var(--gray-mid);
    font-weight: 400;
    transition: color 0.2s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub-links a:hover {
    color: var(--sapphire);
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 960px) {
    .cl-locations { padding: 72px 24px; }
    .main-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .sub-grid  { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .main-card { padding: 24px 20px; }
    .sub-card  { padding: 16px 14px; }
  }
  @media (max-width: 600px) {
    .main-grid { grid-template-columns: 1fr; }
    .sub-grid  { grid-template-columns: 1fr; }
  }

  /* ── Highlight animation (triggered from map click) ── */
  :global(.dealer-highlight) {
    border-color: var(--sapphire) !important;
    box-shadow: 0 0 0 3px rgba(27, 58, 140, 0.2), 0 8px 24px rgba(27, 58, 140, 0.12) !important;
    animation: dealerPulse 2s ease-out;
  }
  @keyframes dealerPulse {
    0%   { box-shadow: 0 0 0 3px rgba(27, 58, 140, 0.4), 0 8px 24px rgba(27, 58, 140, 0.15); }
    100% { box-shadow: 0 0 0 0px rgba(27, 58, 140, 0), 0 8px 24px rgba(27, 58, 140, 0); }
  }
</style>
