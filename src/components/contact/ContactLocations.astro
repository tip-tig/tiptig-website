  { company: 'TIP TIG Benelux', region: 'Benelux', city: 'Duffel, Belgium', phone: '+32 15 22 31 88', email: 'mathew@tiptig-benelux.com', web: 'www.tiptig-benelux.be' },
  { company: 'TIP TIG China', region: 'China', city: "Xi'an, China", phone: '+86 29 83151958', email: 'info@tiptigchina.com', web: 'www.tiptigchina.com' },
