      { country: 'France', company: 'Orbital Weldingtools', city: 'Frauenberg', phone: '+33 686 001 501', email: 'jp-simon@owt-orbital.fr', web: 'www.owt-orbital.com' },
      { country: 'Spain', company: 'CODESOL', city: 'Barcelona', phone: '+34 935 640 804', email: 'codesol@codesol.com', web: 'www.codesol.com' },
      { country: 'Italy', company: 'Data Welding S.r.l', city: 'Vermezzo con Zelo (MI)', phone: '+39 02 944 9092', email: 'donatella@datawelding.it', web: 'www.datawelding.it' },
      { country: 'United Kingdom', company: 'WB Alloy Welding Products', city: 'Glasgow', phone: '+44 141-648-5880', email: 'welding@wballoys.co.uk', web: 'wballoys.co.uk' },
      { country: 'Finland', company: 'TIP TIG Finland', city: 'Turku', phone: '+358 50 434 5255', email: 'info@tiptig.fi', web: 'tiptig.fi' },
      { country: 'Greece', company: 'Technotronic', city: 'Thessaloniki', phone: '+30 23940 72174', email: 'info@technotronic.gr', web: 'www.technotronic.gr' },
      { country: 'Croatia', company: 'Servus d.o.o.', city: 'Čakovec', phone: '+385 40 390 167', email: 'mail@servus.hr', web: 'servus.hr' },
      { country: 'Slovenia / Balkans', company: 'IPRO ING d.o.o.', city: 'Ljubljana', phone: '+386 1 5611-045', email: 'info@ipro.si', web: 'ipro.si' },
    ]
  },
