    dealers: [
      { country: 'USA — Midwest', company: 'Morgan Industrial Technology', city: 'Ozark, MO', phone: '+1 417-485-4575', email: 'sales@morganitech.com', web: 'www.morganitech.com' },
      { country: 'USA — Southeast', company: 'SEC Industrial', city: 'Peachtree Corners, GA', phone: '+1 404-301-9411', email: 'sales2021@secindustrial.com', web: 'www.secindustrial.com' },
      { country: 'Argentina', company: 'Maquisol Services', city: 'Buenos Aires', phone: '+54 11 4551-5999', email: 'maquisol@maquisol.com', web: 'www.maquisol.com' },
    ]
  },
  {
    name: 'Asia-Pacific',
    dealers: [
      { country: 'Australia — West', company: 'Western Welding Services', city: 'Spearwood, WA', phone: '+61 8 9418 4511', email: 'Bill.DeMamiel@westernwelding.com.au', web: 'www.spwgroup.com.au' },
      { country: 'Australia — East', company: 'South Pacific Welding Group', city: 'Carole Park, QLD', phone: '+61 7 3271 6789', email: 'alan.hay@spwgroup.com.au', web: 'www.spwgroup.com.au' },
    ]
  },
  {
