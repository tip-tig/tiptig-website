---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../home/CTA.astro';
import { ArrowLeft } from '@lucide/astro';

interface Feature {
  title: string;
  desc: string;
}

interface Props {
  title: string;
  subtitle: string;
  metaTitle: string;
  metaDesc: string;
  heroImage: string;
  intro: string;
  features: Feature[];
  applications?: string[];
  clients?: string[];
}

const { title, subtitle, metaTitle, metaDesc, heroImage, intro, features, applications, clients } = Astro.props;
---

<BaseLayout title={metaTitle} description={metaDesc}>

  {/* ── Hero ─────────────────────────────────────── */}
  <section class="ind-hero">
    <div class="ind-hero-bg"></div>
    <div class="ind-hero-inner">
      <a href="/#industries" class="ind-back"><ArrowLeft size={16} /> All Industries</a>
      <div class="ind-hero-eyebrow">Industry</div>
      <h1>{title}</h1>
      <p class="ind-hero-sub">{subtitle}</p>
    </div>
  </section>

  {/* ── Image ────────────────────────────────────── */}
  <section class="ind-image">
    <div class="inner">
      <div class="ind-image-wrap reveal">
        <img src={heroImage} alt={title} loading="eager" />
      </div>
    </div>
  </section>

  {/* ── Intro ────────────────────────────────────── */}
  <section class="ind-intro">
    <div class="inner">
      <div class="ind-intro-text">
        <div class="section-eyebrow reveal"><span>Overview</span></div>
        <h2 class="section-title reveal">TIP TIG in the<br><span class="blue">{title}</span></h2>
        <p class="section-lead reveal">{intro}</p>
      </div>
    </div>
  </section>

  {/* ── Features ─────────────────────────────────── */}
  <section class="ind-features">
    <div class="inner">
      <div class="section-eyebrow reveal"><span>Key Advantages</span></div>
      <h2 class="section-title reveal">Why TIP TIG</h2>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class={`feature-card reveal ${i > 0 ? `reveal-delay-${(i % 3)}` : ''}`}>
            <span class="feature-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Applications (optional) ──────────────────── */}
  {applications && applications.length > 0 && (
    <section class="ind-apps">
      <div class="inner">
        <div class="section-eyebrow reveal"><span>Applications</span></div>
        <h2 class="section-title reveal">Typical Applications</h2>
        <div class="apps-grid">
          {applications.map((app, i) => (
            <div class={`app-tag reveal ${i > 0 ? `reveal-delay-${(i % 3)}` : ''}`}>{app}</div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Clients (optional) ───────────────────────── */}
  {clients && clients.length > 0 && (
    <section class="ind-clients">
      <div class="inner">
        <div class="section-eyebrow reveal"><span>Trusted By</span></div>
        <h2 class="section-title section-title--sm reveal">Industry Leaders Using TIP TIG</h2>
        <div class="clients-row">
          {clients.map((c, i) => (
            <span class={`client-name reveal ${i > 0 ? `reveal-delay-${(i % 3)}` : ''}`}>{c}</span>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA />
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .ind-hero {
    padding: 160px 60px 80px;
    background: var(--white);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .ind-hero-bg {
    position: absolute;
    top: -300px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--sapphire-light) 0%, transparent 70%);
    pointer-events: none;
  }

  .ind-hero-inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes heroIn {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ind-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--gray-mid);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }
  .ind-back:hover { color: var(--sapphire); }

  .ind-hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 20px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .ind-hero-eyebrow::before,
  .ind-hero-eyebrow::after {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .ind-hero h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2.6rem, 5vw, 4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
  }

  .ind-hero-sub {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── Image ──────────────────────────────────────── */
  .ind-image {
    padding: 0 60px 110px;
    background: var(--white);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ind-image-wrap {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--gray-light);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.08);
  }

  .ind-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Intro ──────────────────────────────────────── */
  .ind-intro {
    padding: 110px 60px;
    background: var(--bg);
  }

  .ind-intro-text {
    max-width: 720px;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
  }
  .section-title--sm {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }
  .blue { color: var(--sapphire); }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    font-weight: 300;
  }

  /* ── Features ───────────────────────────────────── */
  .ind-features {
    padding: 110px 60px;
    background: var(--white);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .feature-card {
    background: var(--bg);
    border: 1px solid var(--gray-light);
    border-radius: 14px;
    padding: 32px 28px;
    transition: all 0.25s;
  }
  .feature-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 24px rgba(27, 58, 140, 0.08);
    transform: translateY(-2px);
  }

  .feature-num {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--sapphire);
    background: var(--sapphire-light);
    padding: 4px 10px;
    border-radius: 6px;
    display: inline-block;
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }

  .feature-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--black);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--gray-mid);
    line-height: 1.65;
    font-weight: 300;
  }

  /* ── Applications ───────────────────────────────── */
  .ind-apps {
    padding: 110px 60px;
    background: var(--bg);
  }

  .apps-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 36px;
  }

  .app-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sapphire);
    background: var(--sapphire-light);
    border: 1px solid var(--sapphire-mid);
    padding: 10px 20px;
    border-radius: 10px;
    transition: all 0.2s;
  }
  .app-tag:hover {
    background: var(--sapphire);
    color: white;
    border-color: var(--sapphire);
  }

  /* ── Clients ────────────────────────────────────── */
  .ind-clients {
    padding: 80px 60px;
    background: var(--bg);
  }

  .clients-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 32px;
  }

  .client-name {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--gray-dark);
    background: var(--white);
    border: 1px solid var(--gray-light);
    padding: 12px 24px;
    border-radius: 10px;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 960px) {
    .ind-hero { padding: 120px 24px 56px; }
    .ind-image { padding: 0 24px 72px; }
    .ind-intro { padding: 72px 24px; }
    .ind-features { padding: 72px 24px; }
    .features-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .ind-apps { padding: 72px 24px; }
    .ind-clients { padding: 56px 24px; }
  }

  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .ind-image-wrap { border-radius: 14px; }
  }
</style>
