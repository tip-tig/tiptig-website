---
import { Waves, Shield, Gauge, Thermometer, Droplets, Wrench } from '@lucide/astro';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const benefits = [
  { icon: 'Waves', titleKey: 'tech.wd.b1.title', descKey: 'tech.wd.b1.desc' },
  { icon: 'Shield', titleKey: 'tech.wd.b2.title', descKey: 'tech.wd.b2.desc' },
  { icon: 'Droplets', titleKey: 'tech.wd.b3.title', descKey: 'tech.wd.b3.desc' },
  { icon: 'Gauge', titleKey: 'tech.wd.b4.title', descKey: 'tech.wd.b4.desc' },
  { icon: 'Thermometer', titleKey: 'tech.wd.b5.title', descKey: 'tech.wd.b5.desc' },
  { icon: 'Wrench', titleKey: 'tech.wd.b6.title', descKey: 'tech.wd.b6.desc' },
];

const iconMap: Record<string, any> = { Waves, Shield, Gauge, Thermometer, Droplets, Wrench };
---

<section class="wire-dynamics">
  <div class="inner">
    <div class="section-eyebrow reveal">{t('tech.wd.eyebrow')}</div>
    <h2 class="section-title reveal">{t('tech.wd.title')}<br>{t('tech.wd.title2')}</h2>
    <p class="section-lead reveal">
      {t('tech.wd.desc')}
    </p>

    <div class="benefits-grid">
      {benefits.map((b, i) => {
        const Icon = iconMap[b.icon];
        return (
          <div class={`benefit-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="benefit-icon">
              <Icon size={24} />
            </div>
            <h3>{t(b.titleKey)}</h3>
            <p>{t(b.descKey)}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .wire-dynamics {
    padding: 110px 60px;
    background: var(--bg);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .benefit-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 32px 28px;
    transition: all 0.3s ease;
  }

  .benefit-card:hover {
    border-color: var(--sapphire-mid);
    box-shadow: 0 8px 24px rgba(27, 58, 140, 0.08);
    transform: translateY(-4px);
  }

  .benefit-icon {
    width: 48px;
    height: 48px;
    background: var(--sapphire-light);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sapphire);
    margin-bottom: 20px;
  }

  .benefit-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--black);
    margin-bottom: 8px;
  }

  .benefit-card p {
    font-size: 0.88rem;
    color: var(--gray-mid);
    line-height: 1.65;
    font-weight: 300;
  }

  @media (max-width: 960px) {
    .wire-dynamics { padding: 72px 24px; }
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }
</style>
