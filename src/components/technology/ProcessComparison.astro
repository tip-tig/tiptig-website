---
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const characteristicKeys = [
  'tech.pc.c1', 'tech.pc.c2', 'tech.pc.c3', 'tech.pc.c4', 'tech.pc.c5',
  'tech.pc.c6', 'tech.pc.c7', 'tech.pc.c8', 'tech.pc.c9', 'tech.pc.c10',
  'tech.pc.c11', 'tech.pc.c12', 'tech.pc.c13', 'tech.pc.c14', 'tech.pc.c15',
];

const processes = ['TIP TIG', 'MIG', 'TIG', 'FCAW', 'Stick'];

// Ratings: 3 = best, 2 = good, 1 = poor
const ratings: number[][] = [
  [2, 2, 1, 2, 2],
  [2, 2, 1, 2, 2],
  [3, 2, 1, 2, 1],
  [3, 2, 1, 2, 2],
  [3, 3, 1, 2, 1],
  [3, 2, 2, 2, 2],
  [2, 3, 2, 1, 2],
  [3, 2, 3, 2, 2],
  [3, 2, 3, 1, 1],
  [3, 2, 3, 1, 1],
  [3, 2, 3, 1, 1],
  [3, 2, 3, 2, 1],
  [3, 2, 2, 2, 2],
  [2, 2, 1, 2, 2],
  [3, 2, 2, 2, 1],
];

const weaknessProcesses = [
  { name: 'MIG', keys: ['tech.pc.mig.w1', 'tech.pc.mig.w2', 'tech.pc.mig.w3', 'tech.pc.mig.w4', 'tech.pc.mig.w5'] },
  { name: 'TIG', keys: ['tech.pc.tig.w1', 'tech.pc.tig.w2', 'tech.pc.tig.w3', 'tech.pc.tig.w4', 'tech.pc.tig.w5'] },
  { name: 'Stick', keys: ['tech.pc.stick.w1', 'tech.pc.stick.w2', 'tech.pc.stick.w3', 'tech.pc.stick.w4', 'tech.pc.stick.w5'] },
  { name: 'FCAW', keys: ['tech.pc.fcaw.w1', 'tech.pc.fcaw.w2', 'tech.pc.fcaw.w3', 'tech.pc.fcaw.w4', 'tech.pc.fcaw.w5'] },
];
---

<section class="comparison">
  <div class="inner">
    <div class="section-eyebrow reveal">{t('tech.pc.eyebrow')}</div>
    <h2 class="section-title reveal">{t('tech.pc.title')}<br>{t('tech.pc.title2')}</h2>
    <p class="section-lead reveal">
      {t('tech.pc.desc')}
    </p>

    <div class="table-wrapper reveal">
      <table>
        <thead>
          <tr>
            <th class="th-characteristic">{t('tech.pc.th')}</th>
            {processes.map((p) => (
              <th class={p === 'TIP TIG' ? 'th-highlight' : ''}>{p}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {characteristicKeys.map((cKey, ci) => (
            <tr class={ci === characteristicKeys.length - 1 ? 'row-overall' : ''}>
              <td class="td-characteristic">{t(cKey)}</td>
              {ratings[ci].map((r, pi) => (
                <td class={pi === 0 ? 'td-highlight' : ''}>
                  <span class="stars">
                    {Array.from({ length: 3 }, (_, i) => (
                      <span class={`star ${i < r ? 'star-filled' : 'star-empty'}`}>&#9733;</span>
                    ))}
                  </span>
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="weaknesses-grid reveal">
      {weaknessProcesses.map((wp) => (
        <div class="weakness-card">
          <h4>{wp.name} <span class="weakness-tag">{t('tech.pc.challenges')}</span></h4>
          <ul>
            {wp.keys.map((key) => (
              <li>{t(key)}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .comparison {
    padding: 110px 60px;
    background: var(--bg);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sapphire);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--sapphire);
    border-radius: 2px;
  }

  .section-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-lead {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  /* Table */
  .table-wrapper {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid var(--gray-light);
    background: var(--white);
    margin-bottom: 48px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  thead {
    background: var(--sapphire-light);
  }

  th {
    padding: 16px 20px;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-dark);
    text-align: center;
    border-bottom: 2px solid var(--gray-light);
  }

  .th-characteristic {
    text-align: left;
    width: 220px;
    min-width: 180px;
  }

  .th-highlight {
    color: var(--sapphire);
    background: var(--sapphire-mid);
  }

  td {
    padding: 14px 20px;
    text-align: center;
    border-bottom: 1px solid var(--gray-light);
    font-size: 0.88rem;
  }

  .td-characteristic {
    text-align: left;
    font-weight: 500;
    color: var(--gray-dark);
  }

  .td-highlight {
    background: rgba(27, 58, 140, 0.03);
  }

  .row-overall {
    background: var(--sapphire-light);
  }

  .row-overall .td-characteristic {
    font-weight: 700;
    color: var(--black);
  }

  tr:hover {
    background: rgba(27, 58, 140, 0.02);
  }

  .row-overall:hover {
    background: var(--sapphire-light);
  }

  /* Stars */
  .stars {
    display: inline-flex;
    gap: 2px;
  }

  .star {
    font-size: 0.9rem;
    line-height: 1;
  }

  .star-filled {
    color: var(--sapphire);
  }

  .star-empty {
    color: var(--gray-light);
  }

  .td-highlight .star-filled {
    color: var(--sapphire);
  }

  /* Weaknesses */
  .weaknesses-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .weakness-card {
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: 14px;
    padding: 24px;
  }

  .weakness-card h4 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--black);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .weakness-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--red);
    background: rgba(232, 24, 12, 0.08);
    padding: 3px 8px;
    border-radius: 4px;
  }

  .weakness-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .weakness-card li {
    font-size: 0.82rem;
    color: var(--gray-mid);
    font-weight: 400;
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .weakness-card li::before {
    content: '\2013';
    position: absolute;
    left: 0;
    color: var(--gray-light);
    font-weight: 600;
  }

  @media (max-width: 960px) {
    .comparison { padding: 72px 24px; }
    .weaknesses-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .weaknesses-grid { grid-template-columns: 1fr; }
    .table-wrapper { border-radius: 12px; }
  }
</style>
