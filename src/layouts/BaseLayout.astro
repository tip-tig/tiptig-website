---
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'TIP TIG — The original TIG welding innovation. Up to 300% faster, superior quality, proven ROI. Engineered in Austria.',
  ogImage = '/images/logo-red-blue_new.webp',
  jsonLd,
} = Astro.props;

const siteURL = Astro.site ?? 'https://tiptig.com';
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = new URL(ogImage, siteURL).href;

// --- Organization Schema (every page) ---
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TIP TIG',
  legalName: 'Ing. Siegfried Plasch e.U.',
  url: 'https://tiptig.com',
  logo: 'https://tiptig.com/images/logo-red-blue_new.webp',
  foundingDate: '1997',
  founder: { '@type': 'Person', name: 'Siegfried Plasch' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gewerbepark 16',
    addressLocality: 'Krenglbach',
    postalCode: '4631',
    addressCountry: 'AT',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+43-7249-46795',
    contactType: 'sales',
    availableLanguage: ['English', 'German'],
  },
  sameAs: [
    'https://www.linkedin.com/company/tip-tig/',
  ],
};

// --- BreadcrumbList Schema (nested pages) ---
const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tiptig.com/' },
];

const labelMap: Record<string, string> = {
  industries: 'Industries',
  products: 'Products',
  support: 'Support',
  technology: 'Technology',
  about: 'About',
  contact: 'Contact',
  legal: 'Legal',
  privacy: 'Privacy',
  gtc: 'GTC',
  'roi-calculator': 'ROI Calculator',
  'keyhole-tig-welding': 'Keyhole TIG Welding',
  'weld-overlay-cladding': 'Weld Overlay Cladding',
};

let currentPath = '';
pathSegments.forEach((seg, i) => {
  currentPath += `/${seg}`;
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: i + 2,
    name: labelMap[seg] || seg.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    item: `https://tiptig.com${currentPath}`,
  });
});

const breadcrumbSchema = pathSegments.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Preload critical fonts -->
    <link rel="preload" as="font" href="/fonts/inter-400.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/manrope-700.woff2" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | TIP TIG`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TIP TIG" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | TIP TIG`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title} | TIP TIG</title>

    {/* Structured Data */}
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll Reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(el => observer.observe(el));
    </script>
  </body>
</html>
