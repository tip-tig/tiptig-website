---
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';
import { getLangFromUrl, getAlternatePath, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
  lang?: Locale;
}

const {
  title,
  description = 'TIP TIG — The original TIG welding innovation. Up to 300% faster, superior quality, proven ROI. Engineered in Austria.',
  ogImage = '/images/og-default.jpg',
  jsonLd,
  lang = getLangFromUrl(Astro.url),
} = Astro.props;

const siteURL = Astro.site ?? 'https://tiptig.com';
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = new URL(ogImage, siteURL).href;

// --- hreflang alternates ---
const alternates = getAlternatePath(Astro.url.pathname);

// --- Organization Schema (every page) ---
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TIP TIG',
  legalName: 'Ing. Siegfried Plasch e.U.',
  url: 'https://tiptig.com',
  logo: 'https://tiptig.com/images/logo-red-blue_new.webp',
  foundingDate: '1997',
  founder: { '@type': 'Person', name: 'Siegfried Plasch' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gewerbepark 16',
    addressLocality: 'Krenglbach',
    postalCode: '4631',
    addressCountry: 'AT',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+43-7249-46795',
    contactType: 'sales',
    availableLanguage: ['English', 'German'],
  },
  sameAs: [
    'https://www.linkedin.com/company/tip-tig/',
  ],
};

// --- BreadcrumbList Schema (nested pages) ---
const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean).filter(s => s !== 'de');
const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Home', item: `https://tiptig.com${lang === 'de' ? '/de' : '/'}` },
];

const labelMap: Record<string, Record<string, string>> = {
  en: {
    industries: 'Industries', products: 'Products', support: 'Support',
    technology: 'Technology', about: 'About', contact: 'Contact',
    legal: 'Legal', privacy: 'Privacy', gtc: 'GTC',
    'roi-calculator': 'ROI Calculator',
    'keyhole-tig-welding': 'Keyhole TIG Welding',
    'weld-overlay-cladding': 'Weld Overlay Cladding',
    'control-panel': 'Control Panel Guide',
    'manuals': "Owner's Manuals",
    'software-update': 'Software Updates',
    'warranty': 'Warranty',
    'wire-speed-calculator': 'Wire Speed Calculator',
  },
  de: {
    industries: 'Branchen', products: 'Produkte', support: 'Support',
    technology: 'Technologie', about: 'Über uns', contact: 'Kontakt',
    legal: 'Impressum', privacy: 'Datenschutz', gtc: 'AGB',
    'roi-calculator': 'ROI-Rechner',
    'keyhole-tig-welding': 'Keyhole-WIG-Schweißen',
    'weld-overlay-cladding': 'Auftragschweißen',
    'control-panel': 'Bedienpanel-Anleitung',
    'manuals': 'Bedienungsanleitungen',
    'software-update': 'Software-Updates',
    'warranty': 'Garantie',
    'wire-speed-calculator': 'Drahtgeschwindigkeits-Rechner',
  },
};

let currentPath = lang === 'de' ? '/de' : '';
pathSegments.forEach((seg, i) => {
  currentPath += `/${seg}`;
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: i + 2,
    name: (labelMap[lang] || labelMap.en)[seg] || seg.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    item: `https://tiptig.com${currentPath}`,
  });
});

const breadcrumbSchema = pathSegments.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
} : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Preload critical fonts -->
    <link rel="preload" as="font" href="/fonts/inter-400.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/manrope-700.woff2" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | TIP TIG`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TIP TIG" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | TIP TIG`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates -->
    {alternates.map(alt => (
      <link rel="alternate" hreflang={alt.lang} href={new URL(alt.path, siteURL).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(alternates[0].path, siteURL).href} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1B3A8C" />

    <title>{title} | TIP TIG</title>

    {/* Structured Data */}
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <slot name="head" />
  </head>
  <body>
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      // Scroll Reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(el => observer.observe(el));
    </script>
  </body>
</html>
